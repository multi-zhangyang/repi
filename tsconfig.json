{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@pi-recon/repi-ai": ["./packages/ai/src/index.ts"],
			"@pi-recon/repi-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@pi-recon/repi-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@pi-recon/repi-ai/dist/*": ["./packages/ai/src/*"],
			"@pi-recon/repi-agent-core": ["./packages/agent/src/index.ts"],
			"@pi-recon/repi-agent-core/node": ["./packages/agent/src/node.ts"],
			"@pi-recon/repi-agent-core/*": ["./packages/agent/src/*"],
			"@pi-recon/repi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@pi-recon/repi-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@pi-recon/repi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@pi-recon/repi-tui": ["./packages/tui/src/index.ts"],
			"@pi-recon/repi-tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["**/dist/**", "packages/coding-agent/examples/extensions/gondolin/**"]
}
