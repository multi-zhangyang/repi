{
	"name": "repi-monorepo",
	"version": "0.1.3",
	"private": true,
	"description": "REPI reverse/pentest monorepo: autonomous CLI agent for reverse engineering and penetration testing",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/multi-zhangyang/repi.git"
	},
	"bugs": {
		"url": "https://github.com/multi-zhangyang/repi/issues"
	},
	"homepage": "https://github.com/multi-zhangyang/repi#readme",
	"packageManager": "npm@11.12.1",
	"engines": {
		"node": ">=22.19.0"
	},
	"type": "module",
	"keywords": [
		"repi",
		"reverse-pentest",
		"reverse-engineering",
		"penetration-testing",
		"llm-agent",
		"pwn",
		"web-pentest",
		"malware-analysis"
	],
	"workspaces": [
		"packages/*",
		"packages/coding-agent/examples/extensions/with-deps",
		"packages/coding-agent/examples/extensions/custom-provider-anthropic",
		"packages/coding-agent/examples/extensions/custom-provider-gitlab-duo",
		"packages/coding-agent/examples/extensions/sandbox",
		"packages/coding-agent/examples/extensions/gondolin"
	],
	"scripts": {
		"clean": "npm run clean --workspaces",
		"build": "cd packages/tui && npm run build && cd ../ai && npm run build && cd ../agent && npm run build && cd ../coding-agent && npm run build",
		"check": "biome check --write --error-on-warnings . && npm run check:pinned-deps && npm run check:ts-imports && npm run check:shrinkwrap && tsgo --noEmit && npm run contract:repi && npm run check:browser-smoke",
		"check:browser-smoke": "node scripts/check-browser-smoke.mjs",
		"check:pinned-deps": "node scripts/check-pinned-deps.mjs",
		"check:shrinkwrap": "node scripts/generate-coding-agent-shrinkwrap.mjs --check",
		"check:ts-imports": "node scripts/check-ts-relative-imports.mjs",
		"profile:tui": "node scripts/profile-coding-agent-node.mjs --mode tui",
		"profile:rpc": "node scripts/profile-coding-agent-node.mjs --mode rpc",
		"test": "npm run test --workspaces --if-present",
		"version:patch": "npm version patch -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:minor": "npm version minor -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:major": "npm version major -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:set": "npm version -ws",
		"prepublishOnly": "npm run clean && npm run build && npm run check",
		"publish": "npm run prepublishOnly && node scripts/publish.mjs",
		"publish:dry": "npm run prepublishOnly && node scripts/publish.mjs --dry-run",
		"release:local": "node scripts/local-release.mjs",
		"shrinkwrap:coding-agent": "node scripts/generate-coding-agent-shrinkwrap.mjs",
		"release:patch": "node scripts/release.mjs patch",
		"release:minor": "node scripts/release.mjs minor",
		"release:major": "node scripts/release.mjs major",
		"prepare": "husky",
		"install:repi": "bash scripts/reverse-agent/install-repi.sh .",
		"doctor:repi": "node scripts/reverse-agent/repi-doctor.mjs .",
		"contract:repi": "node scripts/reverse-agent/repi-product-contract.mjs .",
		"smoke:repi": "node scripts/reverse-agent/repi-smoke.mjs .",
		"smoke:install-path": "node scripts/reverse-agent/repi-install-path-smoke.mjs .",
		"selfcheck:repi": "node scripts/reverse-agent/repi-selfcheck.mjs .",
		"memory:consolidate": "node scripts/reverse-agent/memory-consolidate.mjs .",
		"clean:repi-legacy-profile": "bash scripts/reverse-agent/clean-global-repi-profile.sh",
		"clean:repi-legacy-profile:apply": "bash scripts/reverse-agent/clean-global-repi-profile.sh --apply",
		"clean:repi-legacy-profile:force-tools": "bash scripts/reverse-agent/clean-global-repi-profile.sh --apply --force-tools",
		"memory:status": "node scripts/reverse-agent/memory-inspect.mjs . status",
		"memory:diff": "node scripts/reverse-agent/memory-inspect.mjs . diff",
		"model:doctor": "node scripts/reverse-agent/model-inspect.mjs . doctor",
		"model:cost": "node scripts/reverse-agent/model-inspect.mjs . cost",
		"doctor:repi:fix": "node scripts/reverse-agent/repi-doctor.mjs . --fix",
		"bugreport:repi": "node scripts/reverse-agent/repi-bugreport.mjs .",
		"memory:list": "node scripts/reverse-agent/memory-inspect.mjs . list",
		"memory:doctor": "node scripts/reverse-agent/memory-inspect.mjs . doctor",
		"model:list": "node scripts/reverse-agent/model-inspect.mjs . list",
		"model:export": "node scripts/reverse-agent/model-inspect.mjs . export",
		"setup:repi": "bash install.sh",
		"update:repi": "bash scripts/reverse-agent/update-repi.sh .",
		"health:repi": "node scripts/reverse-agent/repi-health.mjs .",
		"mission:repi": "node scripts/reverse-agent/repi-mission.mjs . status",
		"engage:repi": "node scripts/reverse-agent/repi-engage.mjs . . --json",
		"smoke:release": "node scripts/reverse-agent/repi-release-tarball-smoke.mjs",
		"smoke:extensions": "node scripts/reverse-agent/repi-extension-compat-smoke.mjs"
	},
	"devDependencies": {
		"@anthropic-ai/sandbox-runtime": "0.0.26",
		"@biomejs/biome": "2.3.5",
		"@types/node": "22.19.19",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"esbuild": "0.28.1",
		"husky": "9.1.7",
		"jiti": "2.7.0",
		"shx": "0.4.0",
		"tsx": "4.22.1",
		"typescript": "5.9.3"
	},
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		},
		"shell-quote": "1.10.0",
		"undici": "8.7.0",
		"@earendil-works/gondolin": {
			"undici": "6.27.0"
		},
		"ws": "8.21.0",
		"protobufjs": "7.6.5",
		"esbuild": "0.28.1",
		"vite": "7.3.6",
		"brace-expansion": "5.0.7"
	},
	"dependencies": {
		"brace-expansion": "5.0.7"
	}
}
