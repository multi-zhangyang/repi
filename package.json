{
	"name": "repi-monorepo",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/*",
		"packages/coding-agent/examples/extensions/with-deps",
		"packages/coding-agent/examples/extensions/custom-provider-anthropic",
		"packages/coding-agent/examples/extensions/custom-provider-gitlab-duo",
		"packages/coding-agent/examples/extensions/sandbox",
		"packages/coding-agent/examples/extensions/gondolin"
	],
	"scripts": {
		"clean": "npm run clean --workspaces",
		"build": "cd packages/tui && npm run build && cd ../ai && npm run build && cd ../agent && npm run build && cd ../coding-agent && npm run build",
		"check": "biome check --write --error-on-warnings . && npm run check:pinned-deps && npm run check:ts-imports && npm run check:shrinkwrap && tsgo --noEmit && npm run check:browser-smoke",
		"check:browser-smoke": "node scripts/check-browser-smoke.mjs",
		"check:pinned-deps": "node scripts/check-pinned-deps.mjs",
		"check:shrinkwrap": "node scripts/generate-coding-agent-shrinkwrap.mjs --check",
		"check:ts-imports": "node scripts/check-ts-relative-imports.mjs",
		"profile:tui": "node scripts/profile-coding-agent-node.mjs --mode tui",
		"profile:rpc": "node scripts/profile-coding-agent-node.mjs --mode rpc",
		"gate:frontier-matrix": "node bench/recon-remote/frontier-matrix/run.mjs --strict",
		"gate:same-window-live": "node bench/recon-remote/same-window-live/run.mjs --strict",
		"gate:agent-parallel": "node bench/recon-remote/agent-dogfood/parallel-run.mjs",
		"gate:compound-frontier": "node bench/recon-remote/compound-frontier/run.mjs --live --strict",
		"gate:context-compact": "node scripts/reverse-agent/context-compact-audit.mjs .",
		"gate:memory-contract": "node scripts/reverse-agent/memory-contract-gate.mjs . --strict",
		"gate:autonomy-control": "node scripts/reverse-agent/autonomy-control-plane.mjs . --strict",
		"audit:hard-eval-control": "node scripts/reverse-agent/hard-eval-control-plane.mjs .",
		"audit:claim-ledger": "node scripts/reverse-agent/hard-eval-control-plane.mjs . --json | node scripts/reverse-agent/validate-claim-ledger.mjs --stdin --allow-platform-gaps",
		"gate:claim-release": "node scripts/reverse-agent/hard-eval-control-plane.mjs . --json | node scripts/reverse-agent/validate-claim-ledger.mjs --stdin --strict-claims --write-marker",
		"gate:runtime-claim-ledger": "node scripts/reverse-agent/gate-runtime-claim-ledger.mjs . --strict",
		"audit:parallel-plan": "node scripts/reverse-agent/audit-parallel-plan.mjs . --strict",
		"gate:autonomous-contracts": "node scripts/reverse-agent/autonomous-contracts.mjs . --strict",
		"test": "npm run test --workspaces --if-present",
		"version:patch": "npm version patch -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:minor": "npm version minor -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:major": "npm version major -ws --no-git-tag-version && node scripts/sync-versions.js && npm install --package-lock-only --ignore-scripts",
		"version:set": "npm version -ws",
		"prepublishOnly": "npm run clean && npm run build && npm run check",
		"publish": "npm run prepublishOnly && node scripts/publish.mjs",
		"publish:dry": "npm run prepublishOnly && node scripts/publish.mjs --dry-run",
		"release:local": "node scripts/local-release.mjs",
		"shrinkwrap:coding-agent": "node scripts/generate-coding-agent-shrinkwrap.mjs",
		"release:patch": "node scripts/release.mjs patch",
		"release:minor": "node scripts/release.mjs minor",
		"release:major": "node scripts/release.mjs major",
		"prepare": "husky",
		"gate:autonomous-runtime": "node scripts/reverse-agent/autonomous-runtime-contracts.mjs . --strict",
		"gate:repi-isolation": "node scripts/reverse-agent/assert-repi-isolated.mjs .",
		"install:repi": "bash scripts/reverse-agent/install-repi.sh .",
		"gate:repi-product": "node scripts/reverse-agent/assert-repi-product.mjs .",
		"gate:repi-harness": "node scripts/reverse-agent/repi-top-harness.mjs . --strict",
		"gate:repi-top-harness": "node scripts/reverse-agent/repi-top-harness.mjs . --strict",
		"clean:repi-legacy-profile": "bash scripts/reverse-agent/clean-global-repi-profile.sh",
		"gate:repi-product-surface": "node scripts/reverse-agent/repi-product-surface-audit.mjs . --strict"
	},
	"devDependencies": {
		"@anthropic-ai/sandbox-runtime": "0.0.26",
		"@biomejs/biome": "2.3.5",
		"@types/node": "22.19.19",
		"@typescript/native-preview": "7.0.0-dev.20260120.1",
		"esbuild": "0.28.0",
		"husky": "9.1.7",
		"jiti": "2.7.0",
		"shx": "0.4.0",
		"tsx": "4.22.1",
		"typescript": "5.9.3"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"version": "0.0.3",
	"overrides": {
		"rimraf": "6.1.2",
		"gaxios": {
			"rimraf": "6.1.2"
		}
	}
}
