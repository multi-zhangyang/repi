{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/professional-runtime-bridges.schema.json",
  "title": "ProfessionalRuntimeBridgesGateV1",
  "description": "professional_runtime_bridge_gate / runtime_execution_bridge_matrix / real_toolchain_bridge_contract / exploit_verifier_runtime_contract / web_cdp_replay_contract / mobile_frida_dynamic_bridge_contract / artifact_backed_tool_execution_plan / env_ref_secret_boundary / runtime:professional-runtime-bridges",
  "type": "object",
  "required": ["kind", "schemaVersion", "ProfessionalRuntimeBridgesGateV1", "runtime", "requiredGates", "bridges", "closure", "nextRuntimeCommands", "negativeCases", "invariants"],
  "properties": {
    "kind": { "const": "ProfessionalRuntimeBridgesGateV1" },
    "schemaVersion": { "const": 1 },
    "ProfessionalRuntimeBridgesGateV1": { "const": true },
    "runtime": { "const": "runtime:professional-runtime-bridges" },
    "requiredGates": {
      "type": "array",
      "contains": { "const": "professional_runtime_bridge_gate" }
    },
    "bridges": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["bridgeId", "domains", "fallbackTools", "commandTemplates", "artifactPlan", "envRefs", "proofExit", "nextRuntimeCommands"],
        "properties": {
          "bridgeId": { "type": "string" },
          "domains": { "type": "array", "minItems": 1 },
          "fallbackTools": { "type": "array", "minItems": 1 },
          "commandTemplates": { "type": "array", "minItems": 3 },
          "artifactPlan": { "type": "array", "minItems": 3 },
          "envRefs": { "type": "array", "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]+$" } },
          "proofExit": { "type": "array", "minItems": 5 },
          "nextRuntimeCommands": { "type": "array", "contains": { "type": "string", "pattern": "re_runtime_bridge" } }
        }
      }
    },
    "closure": {
      "type": "object",
      "required": ["allBridgeSpecsPresent", "allFallbacksAvailable", "allHaveExecutableTemplates", "allHaveArtifactPlans", "allHaveProofExitMappings", "allEnvRefsSecretFree", "fixtureParity"],
      "properties": {
        "allBridgeSpecsPresent": { "const": true },
        "allFallbacksAvailable": { "const": true },
        "allHaveExecutableTemplates": { "const": true },
        "allHaveArtifactPlans": { "const": true },
        "allHaveProofExitMappings": { "const": true },
        "allEnvRefsSecretFree": { "const": true },
        "fixtureParity": { "const": true }
      }
    },
    "nextRuntimeCommands": { "type": "array", "contains": { "type": "string", "pattern": "re_runtime_bridge" } },
    "negativeCases": { "type": "array", "minItems": 7 },
    "invariants": { "type": "array", "minItems": 8 }
  }
}
