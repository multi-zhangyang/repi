{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/release-evidence-index.schema.json",
  "title": "ReleaseEvidenceIndexGateV1",
  "description": "release_evidence_index_gate: release evidence from autonomy control, closure readiness, capability bundle, CI pipeline, source hashes, and command outputs must be merged into a single secret-free indexed evidence bundle with hash-chain rows.",
  "type": "object",
  "required": ["kind", "schemaVersion", "generatedAt", "ReleaseEvidenceIndexGateV1", "requiredGates", "evidenceIndex", "negativeCases", "invariants"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "ReleaseEvidenceIndexGateV1" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "ReleaseEvidenceIndexGateV1": { "const": true },
    "requiredGates": {
      "type": "array",
      "minItems": 8,
      "items": {
        "enum": [
          "release_evidence_index_has_source_hashes",
          "release_evidence_index_has_command_artifacts",
          "release_evidence_index_links_autonomy_gap_ledger",
          "release_evidence_index_links_closure_readiness",
          "release_evidence_index_links_capability_bundle",
          "release_evidence_index_links_ci_pipeline",
          "release_evidence_index_hash_chain_valid",
          "release_evidence_index_secret_free"
        ]
      }
    },
    "evidenceIndex": { "$ref": "#/$defs/ReleaseEvidenceIndexV1" },
    "negativeCases": { "type": "array", "minItems": 8, "items": { "$ref": "#/$defs/ReleaseEvidenceIndexNegativeCaseV1" } },
    "invariants": { "type": "array", "minItems": 8, "items": { "type": "string" } }
  },
  "$defs": {
    "ReleaseEvidenceSourceFileV1": {
      "type": "object",
      "required": ["path", "exists", "sha256", "bytes"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "exists": { "const": true },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "ReleaseEvidenceCommandV1": {
      "type": "object",
      "required": ["id", "command", "code", "stdoutSha256", "stderrSha256", "parsedKind", "secretFree"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "code": { "const": 0 },
        "stdoutSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "stderrSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "parsedKind": {
          "enum": [
            "pi-recon-autonomy-control-plane",
            "repi-autonomous-closure-readiness-gate",
            "repi-capability-release-bundle-gate",
            "repi-release-ci-pipeline-gate"
          ]
        },
        "secretFree": { "const": true }
      }
    },
    "ReleaseEvidenceIndexRowV1": {
      "type": "object",
      "required": ["seq", "evidenceId", "evidenceType", "sourceRef", "sha256", "prevHash", "rowHash"],
      "additionalProperties": false,
      "properties": {
        "seq": { "type": "integer", "minimum": 1 },
        "evidenceId": { "type": "string", "minLength": 1 },
        "evidenceType": { "enum": ["source_file", "command_output", "parsed_summary"] },
        "sourceRef": { "type": "string", "minLength": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "prevHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "rowHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "ReleaseEvidenceSummaryV1": {
      "type": "object",
      "required": ["normalUseGuarantee", "topAutonomousDefinition", "closureReadyRows", "closureClosedRows", "closureFailedRows", "capabilityClaimCount", "ciWorkflowCount"],
      "additionalProperties": false,
      "properties": {
        "normalUseGuarantee": { "const": true },
        "topAutonomousDefinition": { "const": true },
        "closureReadyRows": { "type": "integer", "minimum": 0 },
        "closureClosedRows": { "type": "integer", "minimum": 1 },
        "closureFailedRows": { "const": 0 },
        "capabilityClaimCount": { "type": "integer", "minimum": 4 },
        "ciWorkflowCount": { "type": "integer", "minimum": 2 }
      }
    },
    "ReleaseEvidenceIndexV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "releaseId", "gitHead", "sourceFiles", "commandEvidence", "indexRows", "summary", "hashChainTip", "promotionPolicy"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "ReleaseEvidenceIndexV1" },
        "schemaVersion": { "const": 1 },
        "releaseId": { "type": "string", "minLength": 1 },
        "gitHead": { "type": "string", "minLength": 7 },
        "sourceFiles": { "type": "array", "minItems": 8, "items": { "$ref": "#/$defs/ReleaseEvidenceSourceFileV1" } },
        "commandEvidence": { "type": "array", "minItems": 4, "items": { "$ref": "#/$defs/ReleaseEvidenceCommandV1" } },
        "indexRows": { "type": "array", "minItems": 12, "items": { "$ref": "#/$defs/ReleaseEvidenceIndexRowV1" } },
        "summary": { "$ref": "#/$defs/ReleaseEvidenceSummaryV1" },
        "hashChainTip": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "promotionPolicy": {
          "type": "object",
          "required": ["mode", "allCommandsMustPass", "allSourcesMustHash", "secretFreeRequired", "topAutonomousRequiresClosedGaps"],
          "additionalProperties": false,
          "properties": {
            "mode": { "const": "release_evidence_index" },
            "allCommandsMustPass": { "const": true },
            "allSourcesMustHash": { "const": true },
            "secretFreeRequired": { "const": true },
            "topAutonomousRequiresClosedGaps": { "const": true }
          }
        }
      }
    },
    "ReleaseEvidenceIndexNegativeCaseV1": {
      "type": "object",
      "required": ["id", "mutates", "expect", "mustReject"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "enum": [
            "missing-autonomy-gap-ledger",
            "missing-closure-readiness-ref",
            "missing-capability-bundle-ref",
            "missing-ci-pipeline-ref",
            "command-nonzero-promoted",
            "source-hash-missing",
            "hash-chain-drift",
            "secret-leak-in-command"
          ]
        },
        "mutates": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "expect": { "const": "fail" },
        "mustReject": { "const": true }
      }
    },
    "ReleaseEvidenceIndexGateV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "generatedAt", "ReleaseEvidenceIndexGateV1", "requiredGates", "evidenceIndex", "negativeCases", "invariants"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "ReleaseEvidenceIndexGateV1" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string" },
        "ReleaseEvidenceIndexGateV1": { "const": true },
        "requiredGates": { "type": "array", "minItems": 8, "items": { "type": "string" } },
        "evidenceIndex": { "$ref": "#/$defs/ReleaseEvidenceIndexV1" },
        "negativeCases": { "type": "array", "minItems": 8, "items": { "$ref": "#/$defs/ReleaseEvidenceIndexNegativeCaseV1" } },
        "invariants": { "type": "array", "minItems": 8, "items": { "type": "string" } }
      }
    }
  },
  "x-repiInvariants": [
    "release_evidence_index_has_source_hashes",
    "release_evidence_index_has_command_artifacts",
    "release_evidence_index_links_autonomy_gap_ledger",
    "release_evidence_index_links_closure_readiness",
    "release_evidence_index_links_capability_bundle",
    "release_evidence_index_links_ci_pipeline",
    "release_evidence_index_hash_chain_valid",
    "release_evidence_index_secret_free"
  ]
}
