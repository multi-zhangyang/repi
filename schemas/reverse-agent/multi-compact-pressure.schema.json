{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-recon.local/schemas/multi-compact-pressure.schema.json",
  "title": "REPI MultiCompactPressureGateV1",
  "$defs": {
    "MultiCompactPressureGateNameV1": {
      "type": "string",
      "enum": [
        "MultiCompactPressureGateV1",
        "multi_compact_append_only_pressure",
        "old_context_path_over_latest_fallback",
        "duplicate_resume_idempotency_replay",
        "auto_resume_budget_exhaustion_pressure",
        "scope_artifact_drift_negative_cases",
        "operator_proof_loop_compact_writeback"
      ]
    },
    "MultiCompactPressureRuntimeCycleV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "packTarget",
        "resumeTarget",
        "expectedTransitions",
        "mustEmbedCompactResumeLedgerV2"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "packTarget": {
          "type": "string",
          "minLength": 1
        },
        "resumeTarget": {
          "type": "string",
          "minLength": 1
        },
        "expectedTransitions": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(queued|running|blocked|done|exhausted)->(queued|running|blocked|done|exhausted)$"
          },
          "minItems": 3
        },
        "mustEmbedCompactResumeLedgerV2": {
          "const": true
        }
      }
    },
    "MultiCompactPressureNegativeCaseV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "expect"
      ],
      "properties": {
        "id": {
          "type": "string",
          "enum": [
            "target-unresolved",
            "latest-fallback-without-explicit-ref",
            "scope-mismatch",
            "artifact-drift",
            "budget-exhausted"
          ]
        },
        "expect": {
          "type": "string",
          "minLength": 1
        },
        "mustNotPromote": {
          "type": "boolean"
        }
      }
    },
    "MultiCompactPressureReportV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "MultiCompactPressureGateV1",
        "requiredGates",
        "runtimeCycles",
        "negativeCases",
        "operatorProofWriteback"
      ],
      "properties": {
        "kind": {
          "const": "repi-multi-compact-pressure-report"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "MultiCompactPressureGateV1": {
          "const": true
        },
        "requiredGates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureGateNameV1"
          },
          "minItems": 7,
          "uniqueItems": true
        },
        "runtimeCycles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureRuntimeCycleV1"
          },
          "minItems": 2
        },
        "negativeCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureNegativeCaseV1"
          },
          "minItems": 5
        },
        "operatorProofWriteback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requiresSessionCompactHook",
            "requiresOperatorDispatch",
            "requiresProofLoopRun",
            "requiresCompactResumeTelemetryTransition"
          ],
          "properties": {
            "requiresSessionCompactHook": {
              "const": true
            },
            "requiresOperatorDispatch": {
              "const": true
            },
            "requiresProofLoopRun": {
              "const": true
            },
            "requiresCompactResumeTelemetryTransition": {
              "const": true
            }
          }
        }
      }
    },
    "MultiCompactPressureGateV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "MultiCompactPressureGateV1",
        "requiredGates",
        "runtimeCycles",
        "negativeCases",
        "operatorProofWriteback"
      ],
      "properties": {
        "kind": {
          "const": "repi-multi-compact-pressure-report"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "MultiCompactPressureGateV1": {
          "const": true
        },
        "requiredGates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureGateNameV1"
          },
          "minItems": 7,
          "uniqueItems": true
        },
        "runtimeCycles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureRuntimeCycleV1"
          },
          "minItems": 2
        },
        "negativeCases": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MultiCompactPressureNegativeCaseV1"
          },
          "minItems": 5
        },
        "operatorProofWriteback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requiresSessionCompactHook",
            "requiresOperatorDispatch",
            "requiresProofLoopRun",
            "requiresCompactResumeTelemetryTransition"
          ],
          "properties": {
            "requiresSessionCompactHook": {
              "const": true
            },
            "requiresOperatorDispatch": {
              "const": true
            },
            "requiresProofLoopRun": {
              "const": true
            },
            "requiresCompactResumeTelemetryTransition": {
              "const": true
            }
          }
        }
      },
      "title": "MultiCompactPressureGateV1 control contract",
      "x-repiInvariants": [
        "multi_compact_append_only_pressure",
        "old_context_path_over_latest_fallback",
        "duplicate_resume_idempotency_replay",
        "auto_resume_budget_exhaustion_pressure",
        "scope_artifact_drift_negative_cases",
        "operator_proof_loop_compact_writeback"
      ]
    }
  },
  "x-repiInvariants": [
    "multi_compact_append_only_pressure",
    "old_context_path_over_latest_fallback",
    "duplicate_resume_idempotency_replay",
    "auto_resume_budget_exhaustion_pressure",
    "scope_artifact_drift_negative_cases",
    "operator_proof_loop_compact_writeback"
  ]
}
