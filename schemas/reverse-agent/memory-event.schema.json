{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/memory-event.schema.json",
  "title": "REPI Memory v2 Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["kind", "schemaVersion", "events", "caseMemory", "retrievalReport"],
  "properties": {
    "kind": { "const": "repi-memory-contract" },
    "schemaVersion": { "const": 1 },
    "events": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/MemoryEventV1" } },
    "caseMemory": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/CaseMemoryV1" } },
    "retrievalReport": { "$ref": "#/$defs/MemoryRetrievalReportV1" }
  },
  "$defs": {
    "Sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "StringList": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "MemoryQuality": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confidence", "replayVerified", "reuseCount", "failureCount", "lastUsefulAt", "decay"],
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "replayVerified": { "type": "boolean" },
        "reuseCount": { "type": "integer", "minimum": 0 },
        "failureCount": { "type": "integer", "minimum": 0 },
        "lastUsefulAt": { "type": "string", "format": "date-time" },
        "decay": { "type": "number", "minimum": 0 },
        "retrievalScore": { "type": "number" }
      }
    },
    "MemoryArtifactHash": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "tier"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "anyOf": [{ "$ref": "#/$defs/Sha256" }, { "type": "null" }] },
        "tier": { "type": "string", "enum": ["runtime_artifact", "process_config", "persisted_state", "persisted_memory", "artifact"] },
        "required": { "type": "boolean" }
      }
    },
    "MemoryEventV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind", "schemaVersion", "id", "seq", "ts", "source", "task", "route", "domainTags", "caseSignature",
        "outcome", "lessons", "failurePatterns", "reuseRules", "commands", "artifacts", "artifactHashes", "quality", "promotion", "prevHash", "entryHash"
      ],
      "properties": {
        "kind": { "const": "repi-memory-event" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string", "pattern": "^mem:[a-f0-9]{20}$" },
        "seq": { "type": "integer", "minimum": 1 },
        "ts": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "enum": ["reflect", "complete", "proof_loop", "autofix", "operator", "manual", "knowledge_graph"] },
        "task": { "type": "string", "minLength": 1 },
        "route": { "type": "string", "minLength": 1 },
        "target": { "type": "string" },
        "domainTags": { "$ref": "#/$defs/StringList" },
        "caseSignature": { "type": "string", "pattern": "^[a-f0-9]{16,64}$" },
        "outcome": { "type": "string", "enum": ["success", "failure", "partial", "blocked", "repair"] },
        "lessons": { "$ref": "#/$defs/StringList" },
        "failurePatterns": { "$ref": "#/$defs/StringList" },
        "reuseRules": { "$ref": "#/$defs/StringList" },
        "commands": { "$ref": "#/$defs/StringList" },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/MemoryArtifactHash" } },
        "artifactHashes": { "type": "array", "items": { "$ref": "#/$defs/MemoryArtifactHash" } },
        "quality": { "$ref": "#/$defs/MemoryQuality" },
        "promotion": {
          "type": "object",
          "additionalProperties": false,
          "required": ["playbookCandidate", "verifierRuleCandidate"],
          "properties": {
            "playbookCandidate": { "type": "boolean" },
            "workerRoutingHint": { "type": "string" },
            "verifierRuleCandidate": { "type": "boolean" }
          }
        },
        "prevHash": { "$ref": "#/$defs/Sha256" },
        "entryHash": { "$ref": "#/$defs/Sha256" }
      }
    },
    "CaseMemoryV1": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "schemaVersion", "id", "ts", "caseSignature", "route", "domainTags", "summary", "eventIds", "commands", "reuseRules", "failurePatterns", "quality", "sourceEvents", "lastEventHash"],
      "properties": {
        "kind": { "const": "repi-case-memory" },
        "schemaVersion": { "const": 1 },
        "id": { "type": "string", "pattern": "^case:[a-f0-9]{16,64}:[0-9]+$" },
        "ts": { "type": "string", "format": "date-time" },
        "caseSignature": { "type": "string", "pattern": "^[a-f0-9]{16,64}$" },
        "route": { "type": "string", "minLength": 1 },
        "target": { "type": "string" },
        "domainTags": { "$ref": "#/$defs/StringList" },
        "summary": { "type": "string", "minLength": 1 },
        "eventIds": { "$ref": "#/$defs/StringList" },
        "commands": { "$ref": "#/$defs/StringList" },
        "reuseRules": { "$ref": "#/$defs/StringList" },
        "failurePatterns": { "$ref": "#/$defs/StringList" },
        "quality": { "$ref": "#/$defs/MemoryQuality" },
        "sourceEvents": { "$ref": "#/$defs/StringList" },
        "lastEventHash": { "$ref": "#/$defs/Sha256" }
      }
    },
    "MemoryRetrievalReportV1": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "schemaVersion", "query", "hashChainOk", "hits"],
      "properties": {
        "kind": { "const": "repi-memory-retrieval-report" },
        "schemaVersion": { "const": 1 },
        "query": { "type": "string" },
        "hashChainOk": { "type": "boolean" },
        "hits": { "type": "array", "items": { "type": "object" } }
      }
    }
  }
}
