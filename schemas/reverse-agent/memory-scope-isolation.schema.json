{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/memory-scope-isolation.schema.json",
  "title": "REPI Memory Scope Isolation V1",
  "description": "MemoryScopeIsolationV1 enforces scope_filter_by_mission_session_workspace_target and blocks cross-session/workspace/target contamination from injection; required markers include cross_session_contamination_negative, cross_workspace_contamination_blocks_injection, cross_target_contamination_blocks_injection, legacy_memory_scope_requires_manual_review, and scope_isolation_report_in_context_pack.",
  "$defs": {
    "MemoryScopeV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "sessionId", "cwd", "workspaceRoot", "branchId"],
      "properties": {
        "kind": { "const": "repi-memory-scope" },
        "schemaVersion": { "const": 1 },
        "missionId": { "type": "string" },
        "sessionId": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "workspaceRoot": { "type": "string", "minLength": 1 },
        "branchId": { "type": "string", "minLength": 1 },
        "route": { "type": "string" },
        "target": { "type": "string" }
      }
    },
    "MemoryScopeIsolationRowV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "eventId", "caseSignature", "currentScope", "verdict", "reasons", "blocksInjection", "recommendedAction"],
      "properties": {
        "kind": { "const": "repi-memory-scope-isolation-row" },
        "schemaVersion": { "const": 1 },
        "eventId": { "type": "string", "minLength": 1 },
        "caseSignature": { "type": "string", "minLength": 1 },
        "eventScope": { "$ref": "#/$defs/MemoryScopeV1" },
        "currentScope": { "$ref": "#/$defs/MemoryScopeV1" },
        "verdict": { "enum": ["allow", "warn", "block"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "blocksInjection": { "type": "boolean" },
        "recommendedAction": { "enum": ["allow", "retain", "quarantine", "manual-review"] }
      }
    },
    "MemoryScopeIsolationReportV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "generatedAt", "MemoryScopeIsolationV1", "scopeIsolationReportPath", "eventCount", "currentScope", "rows", "blockedEventIds", "warnEventIds", "allowedEventIds", "requiredGates"],
      "properties": {
        "kind": { "const": "repi-memory-scope-isolation-report" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string", "format": "date-time" },
        "MemoryScopeIsolationV1": { "const": true },
        "scopeIsolationReportPath": { "type": "string" },
        "eventCount": { "type": "number" },
        "currentScope": { "$ref": "#/$defs/MemoryScopeV1" },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/MemoryScopeIsolationRowV1" } },
        "blockedEventIds": { "type": "array", "items": { "type": "string" } },
        "warnEventIds": { "type": "array", "items": { "type": "string" } },
        "allowedEventIds": { "type": "array", "items": { "type": "string" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
