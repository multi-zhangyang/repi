{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/knowledge-scope-isolation.schema.json",
  "title": "REPI Knowledge Scope Isolation V1",
  "description": "KnowledgeScopeIsolationV1 propagates MemoryScopeIsolationV1 into knowledge graph reuse. Required markers: scope_filter_by_mission_session_workspace_target, knowledge_graph_scope_filter_blocks_quarantined_artifacts, knowledge_graph_command_hints_exclude_scope_blocked_sources, knowledge_scope_isolation_report_in_artifact.",
  "$defs": {
    "MemoryScopeV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "sessionId", "cwd", "workspaceRoot", "branchId"],
      "properties": {
        "kind": { "const": "repi-memory-scope" },
        "schemaVersion": { "const": 1 },
        "missionId": { "type": "string" },
        "sessionId": { "type": "string", "minLength": 1 },
        "cwd": { "type": "string", "minLength": 1 },
        "workspaceRoot": { "type": "string", "minLength": 1 },
        "branchId": { "type": "string", "minLength": 1 },
        "route": { "type": "string" },
        "target": { "type": "string" }
      }
    },
    "KnowledgeScopeIsolationSourceV1": {
      "type": "object",
      "required": ["path", "kind", "verdict", "reasons", "blocksKnowledgeReuse"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "eventId": { "type": "string" },
        "caseSignature": { "type": "string" },
        "verdict": { "enum": ["allow", "warn", "block"] },
        "reasons": { "type": "array", "items": { "type": "string" } },
        "blocksKnowledgeReuse": { "type": "boolean" }
      }
    },
    "KnowledgeScopeIsolationV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "MemoryScopeIsolationV1", "scope_filter_by_mission_session_workspace_target", "reportPath", "currentScope", "checkedSourceCount", "blockedSourceCount", "warnSourceCount", "allowedSourceCount", "blockedEventIds", "warnEventIds", "allowedEventIds", "quarantinedSourceArtifacts", "warnSourceArtifacts", "allowedSourceArtifacts", "sourceRows", "requiredGates"],
      "properties": {
        "kind": { "const": "repi-knowledge-scope-isolation" },
        "schemaVersion": { "const": 1 },
        "MemoryScopeIsolationV1": { "const": true },
        "scope_filter_by_mission_session_workspace_target": { "const": true },
        "reportPath": { "type": "string", "minLength": 1 },
        "currentScope": { "$ref": "#/$defs/MemoryScopeV1" },
        "checkedSourceCount": { "type": "number" },
        "blockedSourceCount": { "type": "number" },
        "warnSourceCount": { "type": "number" },
        "allowedSourceCount": { "type": "number" },
        "blockedEventIds": { "type": "array", "items": { "type": "string" } },
        "warnEventIds": { "type": "array", "items": { "type": "string" } },
        "allowedEventIds": { "type": "array", "items": { "type": "string" } },
        "quarantinedSourceArtifacts": { "type": "array", "items": { "type": "string" } },
        "warnSourceArtifacts": { "type": "array", "items": { "type": "string" } },
        "allowedSourceArtifacts": { "type": "array", "items": { "type": "string" } },
        "sourceRows": { "type": "array", "items": { "$ref": "#/$defs/KnowledgeScopeIsolationSourceV1" } },
        "requiredGates": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
