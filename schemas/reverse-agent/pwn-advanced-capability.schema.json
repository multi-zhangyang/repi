{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/pwn-advanced-capability.schema.json",
  "title": "PwnAdvancedCapabilityGateV1",
  "description": "pwn_advanced_capability_gate / pwn_advanced_command_pack_matrix / pwn_advanced_evidence_anchor_matrix / pwn_advanced_followup_self_heal_matrix / pwn_advanced_toolchain_proof_exit_matrix / runtime:pwn-advanced-capability",
  "type": "object",
  "required": ["kind", "schemaVersion", "PwnAdvancedCapabilityGateV1", "runtime", "requiredGates", "markerGroups", "closure", "rows", "nextRuntimeCommands", "negativeCases", "invariants"],
  "properties": {
    "kind": { "const": "PwnAdvancedCapabilityGateV1" },
    "schemaVersion": { "const": 1 },
    "PwnAdvancedCapabilityGateV1": { "const": true },
    "runtime": { "const": "runtime:pwn-advanced-capability" },
    "requiredGates": { "type": "array", "contains": { "const": "pwn_advanced_capability_gate" } },
    "markerGroups": { "type": "object" },
    "closure": {
      "type": "object",
      "required": ["allCommandPacksPresent", "allAnalyzerAnchorsPresent", "allFollowupsPresent", "allSelfHealPresent", "allProofExitsPresent", "allRouteToolingPresent"],
      "properties": {
        "allCommandPacksPresent": { "const": true },
        "allAnalyzerAnchorsPresent": { "const": true },
        "allFollowupsPresent": { "const": true },
        "allSelfHealPresent": { "const": true },
        "allProofExitsPresent": { "const": true },
        "allRouteToolingPresent": { "const": true }
      }
    },
    "rows": { "type": "array", "minItems": 10 },
    "nextRuntimeCommands": { "type": "array", "contains": { "type": "string", "pattern": "re_exploit_lab" } },
    "negativeCases": { "type": "array", "minItems": 5 },
    "invariants": { "type": "array", "minItems": 2 }
  }
}
