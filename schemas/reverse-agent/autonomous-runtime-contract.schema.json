{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "schemaVersion",
    "runId",
    "subagentRuntimeManifests",
    "parallelShardStates",
    "compactResumeStates",
    "repairBudgetStates",
    "claimPromotionGates"
  ],
  "properties": {
    "kind": {
      "const": "PiReconAutonomousRuntimeBatchV1"
    },
    "schemaVersion": {
      "const": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "subagentRuntimeManifests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/SubagentRuntimeManifestV1"
      }
    },
    "parallelShardStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/ParallelShardStateV1"
      }
    },
    "compactResumeStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/CompactResumeStateV2"
      }
    },
    "repairBudgetStates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/RepairBudgetStateV1"
      }
    },
    "claimPromotionGates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/RuntimeClaimPromotionGateV1"
      }
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/autonomous-runtime-contract.schema.json",
  "title": "REPI Autonomous Runtime Contracts",
  "description": "Strict contracts for independent sub-agent runtime manifests, shard scheduling, compact/resume state, failure repair budgets, and runtime claim promotion gates.",
  "$defs": {
    "ResourceLimits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timeoutMs",
        "maxCommands",
        "maxOutputBytes",
        "cancelOnTimeout"
      ],
      "properties": {
        "timeoutMs": {
          "type": "integer",
          "minimum": 0
        },
        "maxCommands": {
          "type": "integer",
          "minimum": 0
        },
        "maxOutputBytes": {
          "type": "integer",
          "minimum": 0
        },
        "cancelOnTimeout": {
          "type": "boolean"
        }
      }
    },
    "RetryBudget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature",
        "attempt",
        "maxAttempts",
        "remaining",
        "exhausted"
      ],
      "properties": {
        "signature": {
          "type": "string",
          "minLength": 8
        },
        "attempt": {
          "type": "integer",
          "minimum": 0
        },
        "maxAttempts": {
          "type": "integer",
          "minimum": 1
        },
        "remaining": {
          "type": "integer",
          "minimum": 0
        },
        "exhausted": {
          "type": "boolean"
        }
      }
    },
    "ModelDigest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "modelId",
        "modelCalls",
        "toolCalls",
        "toolResults"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "modelId": {
          "type": "string",
          "minLength": 1
        },
        "modelCalls": {
          "type": "integer",
          "minimum": 0
        },
        "toolCalls": {
          "type": "integer",
          "minimum": 0
        },
        "toolResults": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "SubagentRuntimeManifestV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schemaVersion",
        "runId",
        "roleId",
        "workerId",
        "attempt",
        "status",
        "pid",
        "parentPid",
        "sessionDir",
        "stdoutPath",
        "stderrPath",
        "stdoutSha256",
        "stderrSha256",
        "startedAt",
        "endedAt",
        "elapsedMs",
        "exitCode",
        "signal",
        "model",
        "toolCallDigest",
        "claimLedgerPath",
        "failureLedgerPath",
        "repairQueuePath",
        "resourceLimits",
        "retryBudget",
        "mergeKeys",
        "evidenceRefs"
      ],
      "properties": {
        "kind": {
          "const": "SubagentRuntimeManifestV1"
        },
        "schemaVersion": {
          "const": 1
        },
        "runId": {
          "type": "string",
          "minLength": 1
        },
        "roleId": {
          "type": "string",
          "minLength": 1
        },
        "workerId": {
          "type": "string",
          "minLength": 1
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "enum": [
            "queued",
            "running",
            "done",
            "failed",
            "blocked",
            "exhausted",
            "cancelled",
            "rolled_back"
          ]
        },
        "pid": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "parentPid": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "sessionDir": {
          "type": "string",
          "minLength": 1
        },
        "stdoutPath": {
          "type": "string",
          "minLength": 1
        },
        "stderrPath": {
          "type": "string",
          "minLength": 1
        },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{8,64}$"
        },
        "stderrSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{8,64}$"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "elapsedMs": {
          "type": "integer",
          "minimum": 0
        },
        "exitCode": {
          "type": [
            "integer",
            "null"
          ]
        },
        "signal": {
          "type": [
            "string",
            "null"
          ]
        },
        "model": {
          "$ref": "#/$defs/ModelDigest"
        },
        "toolCallDigest": {
          "type": "string",
          "pattern": "^[a-f0-9]{8,64}$"
        },
        "claimLedgerPath": {
          "type": "string",
          "minLength": 1
        },
        "failureLedgerPath": {
          "type": "string",
          "minLength": 1
        },
        "repairQueuePath": {
          "type": "string",
          "minLength": 1
        },
        "resourceLimits": {
          "$ref": "#/$defs/ResourceLimits"
        },
        "retryBudget": {
          "$ref": "#/$defs/RetryBudget"
        },
        "mergeKeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ParallelShardStateV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "shardId",
        "source",
        "state",
        "dependencies",
        "dependents",
        "leaseId",
        "resourceLimits",
        "startedAt",
        "endedAt",
        "resultManifestPath",
        "stdoutSha256",
        "stderrSha256",
        "mergeKeys",
        "blockedReason"
      ],
      "properties": {
        "shardId": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "enum": [
            "re_swarm",
            "frontier-orchestrator",
            "agent-dogfood",
            "operator",
            "manual"
          ]
        },
        "state": {
          "enum": [
            "queued",
            "running",
            "done",
            "failed",
            "blocked",
            "exhausted",
            "cancelled",
            "rolled_back"
          ]
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "leaseId": {
          "type": "string",
          "minLength": 1
        },
        "resourceLimits": {
          "$ref": "#/$defs/ResourceLimits"
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": "string",
          "format": "date-time"
        },
        "resultManifestPath": {
          "type": "string",
          "minLength": 1
        },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{8,64}$"
        },
        "stderrSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{8,64}$"
        },
        "mergeKeys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "blockedReason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "StateTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "at",
        "reason"
      ],
      "properties": {
        "from": {
          "type": [
            "string",
            "null"
          ]
        },
        "to": {
          "type": "string",
          "minLength": 1
        },
        "at": {
          "type": "string",
          "format": "date-time"
        },
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CompactResumeStateV2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "contractId",
        "compactionEntryId",
        "contextPath",
        "contextSha256",
        "queueState",
        "idempotencyKey",
        "transitionLog",
        "resumeBudget",
        "operatorQueueRef",
        "proofLoopEntry",
        "blockedReason"
      ],
      "properties": {
        "contractId": {
          "type": "string",
          "minLength": 1
        },
        "compactionEntryId": {
          "type": "string",
          "minLength": 1
        },
        "contextPath": {
          "type": "string",
          "minLength": 1
        },
        "contextSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "queueState": {
          "enum": [
            "queued",
            "running",
            "done",
            "blocked",
            "exhausted"
          ]
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "transitionLog": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/StateTransition"
          }
        },
        "resumeBudget": {
          "$ref": "#/$defs/RetryBudget"
        },
        "operatorQueueRef": {
          "type": "string",
          "minLength": 1
        },
        "proofLoopEntry": {
          "type": "string",
          "minLength": 1
        },
        "blockedReason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "RepairBudgetStateV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "signature",
        "failureId",
        "repairId",
        "state",
        "retryBudget",
        "allowlist",
        "rollbackCriteria",
        "regressionGates",
        "evidenceWriteback"
      ],
      "properties": {
        "signature": {
          "type": "string",
          "minLength": 8
        },
        "failureId": {
          "type": "string",
          "minLength": 1
        },
        "repairId": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "enum": [
            "queued",
            "running",
            "done",
            "failed",
            "blocked",
            "exhausted",
            "cancelled",
            "rolled_back"
          ]
        },
        "retryBudget": {
          "$ref": "#/$defs/RetryBudget"
        },
        "allowlist": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rollbackCriteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "regressionGates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidenceWriteback": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "RuntimeClaimPromotionGateV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "ledgerPath",
        "hashChainOk",
        "eventTypes",
        "strictValidator",
        "finalPromotionBlocked",
        "unresolvedChallenges",
        "artifactRefs",
        "claimIds",
        "validatorCommand"
      ],
      "properties": {
        "source": {
          "enum": [
            "agent-dogfood",
            "re_swarm",
            "compound-frontier",
            "hard-eval",
            "manual"
          ]
        },
        "ledgerPath": {
          "type": "string",
          "minLength": 1
        },
        "hashChainOk": {
          "type": "boolean"
        },
        "eventTypes": {
          "type": "array",
          "minItems": 5,
          "items": {
            "enum": [
              "artifact_handoff",
              "claim",
              "validation",
              "challenge",
              "resolution"
            ]
          }
        },
        "strictValidator": {
          "const": "validate-claim-ledger.mjs"
        },
        "finalPromotionBlocked": {
          "type": "boolean"
        },
        "unresolvedChallenges": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifactRefs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "claimIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "validatorCommand": {
          "type": "string",
          "pattern": "validate-claim-ledger\\.mjs"
        }
      }
    }
  },
  "x-repiInvariants": [
    "subagent_manifest_records_pid_session_stdout_stderr_model_tool_digest",
    "parallel_shard_state_records_dependencies_timeout_cancel_resource_limits_and_merge_keys",
    "compact_resume_state_is_idempotent_and_tracks_queued_running_done_blocked_exhausted",
    "repair_budget_state_shares_signature_budget_allowlist_rollback_and_regression_gates",
    "claim_promotion_gate_requires_strict_claim_ledger_validator_before_final_promotion"
  ],
  "x-repiStrictFixture": "fixtures/reverse-agent/autonomous-runtime-contract.fixture.json"
}
