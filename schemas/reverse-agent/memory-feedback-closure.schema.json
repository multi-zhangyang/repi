{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/memory-feedback-closure.schema.json",
  "title": "REPI Memory Feedback Closure V1",
  "$defs": {
    "MemoryFeedbackClosureRowV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "eventId",
        "caseSignature",
        "route",
        "targetScope",
        "injectionAction",
        "injectionGrade",
        "feedbackEventIds",
        "feedbackStatus",
        "positiveFeedbackCount",
        "negativeFeedbackCount",
        "blockers",
        "nextCommands"
      ],
      "properties": {
        "kind": {
          "const": "repi-memory-feedback-closure-row"
        },
        "schemaVersion": {
          "const": 1
        },
        "eventId": {
          "type": "string",
          "minLength": 1
        },
        "caseSignature": {
          "type": "string",
          "minLength": 1
        },
        "route": {
          "type": "string"
        },
        "targetScope": {
          "type": "string"
        },
        "injectionAction": {
          "enum": [
            "inject",
            "retain",
            "demote",
            "quarantine",
            "expire",
            "not_injected"
          ]
        },
        "injectionGrade": {
          "type": "number"
        },
        "feedbackEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "feedbackStatus": {
          "enum": [
            "promoted",
            "demoted",
            "pending",
            "orphan_feedback"
          ]
        },
        "positiveFeedbackCount": {
          "type": "number"
        },
        "negativeFeedbackCount": {
          "type": "number"
        },
        "lastFeedbackAt": {
          "type": "string"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "nextCommands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "MemoryFeedbackClosureReportV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "MemoryFeedbackClosureV1",
        "sedimentationReportPath",
        "injectionPacketPath",
        "feedbackClosureReportPath",
        "eventCount",
        "injectedCount",
        "feedbackLinkedCount",
        "feedbackCoverage",
        "closureStatus",
        "rows",
        "promotionReadyEventIds",
        "demotionRequiredEventIds",
        "pendingFeedbackEventIds",
        "orphanFeedbackEventIds",
        "requiredGates"
      ],
      "properties": {
        "kind": {
          "const": "repi-memory-feedback-closure-report"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "MemoryFeedbackClosureV1": {
          "const": true
        },
        "sedimentationReportPath": {
          "type": "string"
        },
        "injectionPacketPath": {
          "type": "string"
        },
        "feedbackClosureReportPath": {
          "type": "string"
        },
        "eventCount": {
          "type": "number"
        },
        "injectedCount": {
          "type": "number"
        },
        "feedbackLinkedCount": {
          "type": "number"
        },
        "feedbackCoverage": {
          "type": "number"
        },
        "closureStatus": {
          "enum": [
            "pass",
            "warn",
            "fail",
            "empty"
          ]
        },
        "rows": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/MemoryFeedbackClosureRowV1"
          }
        },
        "promotionReadyEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "demotionRequiredEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pendingFeedbackEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "orphanFeedbackEventIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requiredGates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "description": "MemoryFeedbackClosureReportV1 includes pending_injection_requires_feedback_writeback in requiredGates."
    }
  },
  "description": "Machine-readable contract for MemoryFeedbackClosureV1; required gate marker: pending_injection_requires_feedback_writeback."
}
