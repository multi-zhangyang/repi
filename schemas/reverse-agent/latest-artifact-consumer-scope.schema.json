{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pi-recon.local/schemas/latest-artifact-consumer-scope.schema.json",
  "title": "REPI LatestArtifactConsumerScopeGateV1",
  "$defs": {
    "LatestArtifactConsumerScopeScenarioV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "consumer",
        "mustSelectSameTargetOlderArtifact",
        "mustBlockCrossTargetLatestArtifact"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "consumer": {
          "type": "string",
          "enum": [
            "operator-feedback",
            "proof-loop-gap",
            "compiler-claim-gate",
            "proof-loop-evidence",
            "proof-loop-source"
          ]
        },
        "mustSelectSameTargetOlderArtifact": {
          "const": true
        },
        "mustBlockCrossTargetLatestArtifact": {
          "const": true
        }
      }
    },
    "LatestArtifactConsumerScopeGateV1": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "LatestArtifactConsumerScopeGateV1",
        "requiredGates",
        "scenarios"
      ],
      "properties": {
        "kind": {
          "const": "repi-latest-artifact-consumer-scope-report"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "LatestArtifactConsumerScopeGateV1": {
          "const": true
        },
        "requiredGates": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "LatestArtifactConsumerScopeGateV1",
              "operator_feedback_latest_artifact_consumer",
              "proof_loop_gap_latest_artifact_consumer",
              "proof_loop_evidence_latest_artifact_consumer",
              "proof_loop_source_latest_artifact_consumer",
              "compiler_claim_gate_latest_artifact_consumer",
              "cross_target_latest_artifact_blocked",
              "same_target_older_artifact_selected"
            ]
          },
          "contains": {
            "const": "cross_target_latest_artifact_blocked"
          }
        },
        "scenarios": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/LatestArtifactConsumerScopeScenarioV1"
          },
          "minItems": 3
        }
      }
    }
  },
  "x-repiInvariants": [
    "latest_artifact_consumer_scope_gate",
    "operator_feedback_latest_artifact_consumer",
    "proof_loop_gap_latest_artifact_consumer",
    "proof_loop_evidence_latest_artifact_consumer",
    "proof_loop_source_latest_artifact_consumer",
    "compiler_claim_gate_latest_artifact_consumer",
    "cross_target_latest_artifact_blocked",
    "same_target_older_artifact_selected"
  ]
}
