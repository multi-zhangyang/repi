{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/provider-backed-dogfood.schema.json",
  "title": "ProviderBackedDogfoodReleaseGateV1",
  "description": "Optional-live REPI gate proving provider-backed agent-dogfood multi-worker execution is not confused with plan-only/runtime-ledger probes.",
  "type": "object",
  "required": ["kind", "schemaVersion", "generatedAt", "mode", "liveRequested", "ok", "releaseGate"],
  "additionalProperties": true,
  "properties": {
    "kind": { "const": "ProviderBackedDogfoodReleaseGateV1" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "mode": { "enum": ["skipped", "live"] },
    "liveRequested": { "type": "boolean" },
    "ok": { "type": "boolean" },
    "skipReason": { "type": "string" },
    "providerName": { "type": "string" },
    "modelIdSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifact": {
      "type": "object",
      "properties": {
        "resultPath": { "type": "string" },
        "artifactDir": { "type": "string" },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "exists": { "type": "boolean" }
      }
    },
    "releaseGate": {
      "type": "object",
      "required": ["planOnlyNotPromoted", "providerBacked", "multiWorker", "synthesizerCaptured", "modelCallsCaptured", "toolResultsCaptured", "subagentManifestsCaptured", "runtimeClaimLedgerCaptured", "nonMockRuntime", "parallelOverlap", "orchestrationPlatformSplitPreserved"],
      "additionalProperties": true,
      "properties": {
        "planOnlyNotPromoted": { "type": "boolean" },
        "providerBacked": { "type": "boolean" },
        "multiWorker": { "type": "boolean" },
        "synthesizerCaptured": { "type": "boolean" },
        "modelCallsCaptured": { "type": "boolean" },
        "toolResultsCaptured": { "type": "boolean" },
        "subagentManifestsCaptured": { "type": "boolean" },
        "runtimeClaimLedgerCaptured": { "type": "boolean" },
        "nonMockRuntime": { "type": "boolean" },
        "parallelOverlap": { "type": "boolean" },
        "orchestrationPlatformSplitPreserved": { "type": "boolean" }
      }
    },
    "negativeCases": {
      "type": "array",
      "items": { "type": "object", "required": ["id", "status"] }
    }
  }
}
