        "continuationAfterExactResume",
        "requestLogSha256",
        "stdoutSha256",
        "stderrSha256",
        "noLiteralSecrets",
        "noPiPollution",
        "status"
      ],
      "additionalProperties": false,
      "properties": {
        "sampleId": {
          "type": "string",
          "minLength": 1
        },
        "cycleId": {
          "type": "string",
          "minLength": 1
        },
        "resumeSessionId": {
          "type": "string",
          "minLength": 1
        },
        "providerName": {
          "type": "string",
          "minLength": 1
        },
        "modelId": {
          "type": "string",
          "minLength": 1
        },
        "apiStyle": {
          "enum": [
            "openai-compatible",
            "anthropic-compatible"
          ]
        },
        "liveOptInEnv": {
          "const": "REPI_REMOTE_PROVIDER_LIVE"
        },
        "apiKeyEnvRefOnly": {
          "const": true
        },
        "continuationAfterExactResume": {
          "const": true
        },
        "requestLogSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "stderrSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "noLiteralSecrets": {
          "const": true
        },
        "noPiPollution": {
          "const": true
        },
        "status": {
          "const": "pass"
        }
      }
    },
    "RemoteProviderContinuationSampleMatrixV1": {
      "type": "object",
      "required": [
        "kind",
        "sampleCount",
        "providerCount",
        "apiStyles",
        "cycleIds",
        "samples",
        "allAfterExactResume",
        "envRefOnly",
        "allRequestLogsHashed",
        "secretFree",
        "noPiPollution"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "RemoteProviderContinuationSampleMatrixV1"
        },
        "sampleCount": {
          "type": "integer",
          "minimum": 5
        },
        "providerCount": {
          "type": "integer",
          "minimum": 3
        },
        "apiStyles": {
          "type": "array",
          "minItems": 2,
          "items": {
            "enum": [
              "openai-compatible",
              "anthropic-compatible"
            ]
          }
        },
        "cycleIds": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "samples": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/RemoteProviderContinuationSampleV1"
          }
        },
        "allAfterExactResume": {
          "const": true
        },
        "envRefOnly": {
          "const": true
        },
        "allRequestLogsHashed": {
          "const": true
        },
        "secretFree": {
          "const": true
        },
        "noPiPollution": {
          "const": true
        }
      }
    },
    "CompactResumeLedgerCycleTerminalAlignmentV1": {
      "type": "object",
      "required": [
        "kind",
        "allCyclesHaveQueuedRunningTerminal",
        "terminalMatchesClosure",
