{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/cross-session-multi-compact-matrix.schema.json",
  "title": "CrossSessionMultiCompactMatrixGateV1",
  "description": "cross_session_multi_compact_matrix_gate: one bounded matrix proves cross-session exact contextPath resume after five compactions, old contextPath over latest fallback, artifact/context hash verification, multi-provider and remote-shaped provider continuation after exact resume, operator/proof-loop closure, and CompactResumeLedgerV2 terminal-row integrity, and per-cycle CompactResumeLedgerV2 terminal alignment.",
  "$defs": {
    "CrossSessionMatrixSessionV1": {
      "type": "object",
      "required": [
        "sessionId",
        "role",
        "profileHome",
        "isolated"
      ],
      "additionalProperties": false,
      "properties": {
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "enum": [
            "source-pack",
            "cross-session-resume",
            "latest-fallback-decoy"
          ]
        },
        "profileHome": {
          "const": "~/.repi/agent"
        },
        "isolated": {
          "const": true
        }
      }
    },
    "CrossSessionArtifactHashV1": {
      "type": "object",
      "required": [
        "path",
        "sha256",
        "required"
      ],
      "additionalProperties": true,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "CrossSessionMultiCompactCycleV1": {
      "type": "object",
      "required": [
        "cycleId",
        "sourceSessionId",
        "resumeSessionId",
        "packTarget",
        "resumeTarget",
        "contextPath",
        "contextSha256",
        "artifactHashes",
        "latestFallbackCandidate",
        "loadedBy",
        "explicitContextPathUsed",
        "oldContextPathBeatsLatestFallback",
        "exactResumeVerification",
        "resumeClosure",
        "providerContinuationId"
      ],
      "additionalProperties": false,
      "properties": {
        "cycleId": {
          "type": "string",
          "minLength": 1
        },
        "sourceSessionId": {
          "type": "string",
          "minLength": 1
        },
        "resumeSessionId": {
          "type": "string",
          "minLength": 1
        },
        "packTarget": {
          "type": "string",
          "minLength": 1
        },
        "resumeTarget": {
          "type": "string",
          "minLength": 1
        },
        "contextPath": {
          "type": "string",
          "minLength": 1
        },
        "contextSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "artifactHashes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/CrossSessionArtifactHashV1"
          }
        },
        "latestFallbackCandidate": {
          "type": "string",
          "minLength": 1
        },
        "loadedBy": {
          "const": "contextPath"
        },
        "explicitContextPathUsed": {
          "const": true
        },
        "oldContextPathBeatsLatestFallback": {
          "const": true
        },
        "exactResumeVerification": {
          "type": "object",
          "required": [
            "contextSha256Match",
            "artifactHashesOk",
            "scopeOk",
            "loadedBy"
          ],
          "additionalProperties": false,
          "properties": {
            "contextSha256Match": {
              "const": true
            },
            "artifactHashesOk": {
              "const": true
            },
            "scopeOk": {
              "const": true
            },
            "loadedBy": {
              "const": "contextPath"
            }
          }
        },
        "resumeClosure": {
          "type": "object",
          "required": [
            "status",
            "closedAt",
            "verifiedBy"
          ],
          "additionalProperties": false,
          "properties": {
            "status": {
              "enum": [
                "done",
                "blocked",
                "exhausted"
              ]
            },
            "closedAt": {
              "type": "string"
            },
            "verifiedBy": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "providerContinuationId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "CrossSessionProviderContinuationV1": {
      "type": "object",
      "required": [
        "cycleId",
        "resumeSessionId",
        "providerName",
        "modelId",
        "apiStyle",
        "apiKeyEnvRefOnly",
        "continuationAfterExactResume",
        "requestLogPath",
        "stdoutPath",
        "stderrPath",
        "requestLogSha256",
        "stdoutSha256",
        "stderrSha256",
        "continuationStatus",
        "noPiHomeImport",
        "noUpdateBanner",
        "noLiteralSecrets"
      ],
      "additionalProperties": false,
      "properties": {
        "cycleId": {
          "type": "string",
          "minLength": 1
        },
        "resumeSessionId": {
          "type": "string",
          "minLength": 1
        },
        "providerName": {
          "type": "string",
          "minLength": 1
        },
        "modelId": {
          "type": "string",
          "minLength": 1
        },
        "apiKeyEnvRefOnly": {
          "const": true
        },
        "requestLogPath": {
          "type": "string",
          "minLength": 1
        },
        "stdoutPath": {
          "type": "string",
          "minLength": 1
        },
        "stderrPath": {
          "type": "string",
          "minLength": 1
        },
        "requestLogSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "stdoutSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "stderrSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "continuationStatus": {
          "const": "pass"
        },
        "noPiHomeImport": {
          "const": true
        },
        "noUpdateBanner": {
          "const": true
        },
        "noLiteralSecrets": {
          "const": true
        },
        "apiStyle": {
          "enum": [
            "openai-compatible",
            "anthropic-compatible"
          ]
        },
        "continuationAfterExactResume": {
          "const": true
        }
      }
    },
    "CrossSessionOperatorProofClosureV1": {
      "type": "object",
      "required": [
        "cycleId",
        "operatorStatus",
        "proofLoopStatus",
        "budget",
        "proofLoopEntered",
        "terminal",
        "terminalReopened",
        "closureReason",
        "verifiedBy"
      ],
      "additionalProperties": false,
      "properties": {
        "cycleId": {
          "type": "string",
          "minLength": 1
        },
        "operatorStatus": {
          "enum": [
            "done",
            "blocked",
            "exhausted"
          ]
        },
        "proofLoopStatus": {
          "enum": [
            "done",
            "blocked",
            "exhausted"
          ]
        },
        "budget": {
          "type": "object",
          "required": [
            "maxOperatorDispatch",
            "maxProofLoops",
            "remaining"
          ],
          "additionalProperties": false,
          "properties": {
            "maxOperatorDispatch": {
              "type": "integer",
              "minimum": 0
            },
            "maxProofLoops": {
              "type": "integer",
              "minimum": 0
            },
            "remaining": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "proofLoopEntered": {
          "const": true
        },
        "terminal": {
          "const": true
        },
        "terminalReopened": {
          "const": false
        },
        "closureReason": {
          "type": "string",
          "minLength": 1
        },
        "verifiedBy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "CompactResumeLedgerTransitionV2": {
      "type": "object",
      "required": [
        "kind",
        "seq",
        "prevHash",
        "cycleId",
        "sessionId",
        "state",
        "contextPath",
        "contextSha256",
        "idempotencyKey",
        "entryHash"
      ],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "const": "CompactResumeLedgerTransitionV2"
        },
        "seq": {
          "type": "integer",
          "minimum": 1
        },
        "prevHash": {
          "type": "string"
        },
        "cycleId": {
          "type": "string",
          "minLength": 1
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "enum": [
            "queued",
            "running",
            "done",
            "blocked",
            "exhausted"
          ]
        },
        "contextPath": {
          "type": "string",
          "minLength": 1
        },
        "contextSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "idempotencyKey": {
          "type": "string",
          "minLength": 1
        },
        "entryHash": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "CrossSessionCompactResumeLedgerV2Ref": {
      "type": "object",
      "required": [
        "kind",
        "transitionPath",
        "transitionSha256",
        "appendOnly",
        "hashChainOk",
        "terminalRowsNotReopened",
        "cycleTerminalAlignmentOk",
        "ledgerCycleAlignment",
        "transitions"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "CompactResumeLedgerV2"
        },
        "transitionPath": {
          "type": "string",
          "minLength": 1
        },
        "transitionSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "appendOnly": {
          "const": true
        },
        "hashChainOk": {
          "const": true
        },
        "terminalRowsNotReopened": {
          "const": true
        },
        "transitions": {
          "type": "array",
          "minItems": 15,
          "items": {
            "$ref": "#/$defs/CompactResumeLedgerTransitionV2"
          }
        },
        "cycleTerminalAlignmentOk": {
          "const": true
        },
        "ledgerCycleAlignment": {
          "$ref": "#/$defs/CompactResumeLedgerCycleTerminalAlignmentV1"
        }
      }
    },
    "CrossSessionMultiCompactMatrixV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "closureGate",
        "missionId",
        "sessions",
        "compactCycles",
        "providerContinuations",
        "providerContinuationMatrix",
        "remoteProviderContinuationSampleMatrix",
        "operatorProofClosures",
        "compactResumeLedger",
        "providerContinuationPolicy",
        "promotionPolicy"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "CrossSessionMultiCompactMatrixV1"
        },
        "schemaVersion": {
          "const": 1
        },
        "closureGate": {
          "const": "gate:cross-session-multi-compact-matrix"
        },
        "missionId": {
          "type": "string",
          "minLength": 1
        },
        "sessions": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/CrossSessionMatrixSessionV1"
          }
        },
        "compactCycles": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/CrossSessionMultiCompactCycleV1"
          }
        },
        "providerContinuations": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/CrossSessionProviderContinuationV1"
          }
        },
        "operatorProofClosures": {
          "type": "array",
          "minItems": 5,
          "items": {
            "$ref": "#/$defs/CrossSessionOperatorProofClosureV1"
          }
        },
        "compactResumeLedger": {
          "$ref": "#/$defs/CrossSessionCompactResumeLedgerV2Ref"
        },
        "providerContinuationPolicy": {
          "type": "object",
          "required": [
            "requiresAfterExactResume",
            "requiresMultiProviderMatrix",
            "requiresEnvRefOnly",
            "requiresRequestLogHash",
            "requiresNoPiPollution"
          ],
          "additionalProperties": false,
          "properties": {
            "requiresAfterExactResume": {
              "const": true
            },
            "requiresEnvRefOnly": {
              "const": true
            },
            "requiresRequestLogHash": {
              "const": true
            },
            "requiresNoPiPollution": {
              "const": true
            },
            "requiresMultiProviderMatrix": {
              "const": true
            }
          }
        },
        "promotionPolicy": {
          "type": "object",
          "required": [
            "mode",
            "requiresCrossSession",
            "requiresMultipleCompacts",
            "requiresExplicitContextPath",
            "requiresProviderContinuation",
            "requiresProviderContinuationMatrix",
            "requiresLongerCompactionChain",
            "requiresOperatorProofClosure",
            "requiresRemoteProviderContinuationSampleMatrix",
            "requiresFiveCycleCompactionChain",
            "requiresLedgerCycleTerminalAlignment"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "const": "block-until-cross-session-multi-compact-provider-proof"
            },
            "requiresCrossSession": {
              "const": true
            },
            "requiresMultipleCompacts": {
              "const": true
            },
            "requiresExplicitContextPath": {
              "const": true
            },
            "requiresProviderContinuation": {
              "const": true
            },
            "requiresOperatorProofClosure": {
              "const": true
            },
            "requiresProviderContinuationMatrix": {
              "const": true
            },
            "requiresLongerCompactionChain": {
              "const": true
            },
            "requiresRemoteProviderContinuationSampleMatrix": {
              "const": true
            },
            "requiresFiveCycleCompactionChain": {
              "const": true
            },
            "requiresLedgerCycleTerminalAlignment": {
              "const": true
            }
          }
        },
        "providerContinuationMatrix": {
          "$ref": "#/$defs/ProviderContinuationMatrixV1"
        },
        "remoteProviderContinuationSampleMatrix": {
          "$ref": "#/$defs/RemoteProviderContinuationSampleMatrixV1"
        }
      }
    },
    "CrossSessionMultiCompactMatrixGateV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "CrossSessionMultiCompactMatrixGateV1",
        "requiredGates",
        "matrix",
        "negativeCases",
        "invariants"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "CrossSessionMultiCompactMatrixGateV1"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string"
        },
        "CrossSessionMultiCompactMatrixGateV1": {
          "const": true
        },
        "requiredGates": {
          "type": "array",
          "minItems": 13,
          "items": {
            "enum": [
              "CrossSessionMultiCompactMatrixGateV1",
              "cross_session_multi_compact_same_run",
              "old_context_path_over_latest_after_multiple_compacts",
              "context_sha_artifact_hashes_verified_across_sessions",
              "provider_continuation_after_exact_resume",
              "provider_continuation_matrix_multi_provider",
              "longer_cross_session_compaction_chain",
              "operator_proof_loop_budget_closure",
              "terminal_resume_rows_not_reopened",
              "compact_resume_ledger_cycle_terminal_alignment",
              "compact_resume_ledger_v2_hash_chain_quality",
              "five_cycle_cross_session_compaction_chain",
              "remote_provider_continuation_sample_matrix"
            ]
          }
        },
        "matrix": {
          "$ref": "#/$defs/CrossSessionMultiCompactMatrixV1"
        },
        "negativeCases": {
          "type": "array",
          "minItems": 15,
          "items": {
            "type": "object",
            "required": [
              "id",
              "mutates",
              "expect",
              "mustNotPromote"
            ],
            "additionalProperties": false,
            "properties": {
              "id": {
                "enum": [
                  "latest-fallback-without-explicit-context",
                  "context-sha-drift",
                  "artifact-hash-drift",
                  "provider-continuation-missing",
                  "budget-exhausted-open",
                  "terminal-row-reopened",
                  "same-session-only",
                  "ledger-hash-chain-drift",
                  "provider-continuation-single-provider",
                  "compact-chain-too-short",
                  "provider-continuation-before-exact-resume",
                  "five-cycle-chain-too-short",
                  "ledger-terminal-missing-after-rehash",
                  "remote-provider-sample-missing",
                  "remote-provider-secret-leak"
                ]
              },
              "mutates": {
                "type": "string"
              },
              "expect": {
                "const": "reject"
              },
              "mustNotPromote": {
                "const": true
              }
            }
          }
        },
        "invariants": {
          "type": "array",
          "minItems": 13,
          "items": {
            "enum": [
              "cross_session_multi_compact_matrix_gate",
              "cross_session_multi_compact_same_run",
              "old_context_path_over_latest_after_multiple_compacts",
              "context_sha_artifact_hashes_verified_across_sessions",
              "provider_continuation_after_exact_resume",
              "operator_proof_loop_budget_closure",
              "terminal_resume_rows_not_reopened",
              "compact_resume_ledger_cycle_terminal_alignment",
              "compact_resume_ledger_v2_hash_chain_quality",
              "provider_continuation_matrix_multi_provider",
              "longer_cross_session_compaction_chain",
              "five_cycle_cross_session_compaction_chain",
              "remote_provider_continuation_sample_matrix"
            ]
          }
        }
      },
      "x-repiInvariants": [
        "cross_session_multi_compact_matrix_gate",
        "cross_session_multi_compact_same_run",
        "old_context_path_over_latest_after_multiple_compacts",
        "context_sha_artifact_hashes_verified_across_sessions",
        "provider_continuation_after_exact_resume",
        "operator_proof_loop_budget_closure",
        "terminal_resume_rows_not_reopened",
        "compact_resume_ledger_cycle_terminal_alignment",
        "compact_resume_ledger_v2_hash_chain_quality",
        "provider_continuation_matrix_multi_provider",
        "longer_cross_session_compaction_chain",
        "five_cycle_cross_session_compaction_chain",
        "remote_provider_continuation_sample_matrix"
      ]
    },
    "ProviderContinuationMatrixV1": {
      "type": "object",
      "required": [
        "kind",
        "providerCount",
        "apiStyles",
        "modelIds",
        "cycleIds",
        "continuationIds",
        "allAfterExactResume",
        "envRefOnly",
        "requestLogHashes",
        "noPiPollution"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "ProviderContinuationMatrixV1"
        },
        "providerCount": {
          "type": "integer",
          "minimum": 3
        },
        "apiStyles": {
          "type": "array",
          "minItems": 2,
          "items": {
            "enum": [
              "openai-compatible",
              "anthropic-compatible"
            ]
          }
        },
        "modelIds": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "cycleIds": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "continuationIds": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "allAfterExactResume": {
          "const": true
        },
        "envRefOnly": {
          "const": true
        },
        "requestLogHashes": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          }
        },
        "noPiPollution": {
          "const": true
        }
      }
    },
    "RemoteProviderContinuationSampleV1": {
      "type": "object",
      "required": [
        "sampleId",
        "cycleId",
        "resumeSessionId",
        "providerName",
        "modelId",
        "apiStyle",
        "liveOptInEnv",
