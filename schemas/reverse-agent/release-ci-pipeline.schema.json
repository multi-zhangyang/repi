{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/release-ci-pipeline.schema.json",
  "title": "ReleaseCiPipelineGateV1",
  "description": "release_ci_pipeline_gate: CI must run REPI product-boundary, isolation, closure-readiness, capability-release, runtime-adapter, top-harness, repository check, and no-diff gates in a safe order without secret-backed/live-provider requirements.",
  "type": "object",
  "required": [
    "kind",
    "schemaVersion",
    "generatedAt",
    "ReleaseCiPipelineGateV1",
    "requiredGates",
    "pipeline",
    "negativeCases",
    "invariants"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": {
      "const": "ReleaseCiPipelineGateV1"
    },
    "schemaVersion": {
      "const": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "ReleaseCiPipelineGateV1": {
      "const": true
    },
    "requiredGates": {
      "type": "array",
      "minItems": 8,
      "items": {
        "enum": [
          "ci_uses_repi_command_not_pi_takeover",
          "ci_installs_with_ignore_scripts",
          "product_boundary_before_capability_claim",
          "closure_readiness_before_capability_release",
          "capability_release_before_top_harness",
          "top_harness_before_repository_check",
          "no_generated_diff_after_checks",
          "ci_no_live_provider_or_secret_dependency",
          "release_ci_pipeline_before_evidence_index",
          "release_evidence_index_before_top_harness",
          "runtime_adapter_execution_before_top_harness"
        ]
      }
    },
    "pipeline": {
      "$ref": "#/$defs/ReleaseCiPipelineV1"
    },
    "negativeCases": {
      "type": "array",
      "minItems": 7,
      "items": {
        "$ref": "#/$defs/ReleaseCiPipelineNegativeCaseV1"
      }
    },
    "invariants": {
      "type": "array",
      "minItems": 8,
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "ReleaseCiStepV1": {
      "type": "object",
      "required": [
        "name",
        "command",
        "order",
        "required",
        "evidenceTier"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "order": {
          "type": "integer",
          "minimum": 0
        },
        "required": {
          "const": true
        },
        "evidenceTier": {
          "enum": [
            "install",
            "product_boundary",
            "closure_readiness",
            "capability_release",
            "top_harness",
            "repository_check",
            "diff_guard",
            "release_ci_pipeline",
            "release_evidence_index",
            "runtime_adapter_execution"
          ]
        }
      }
    },
    "ReleaseCiWorkflowV1": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256",
        "nodeVersion",
        "permissionsReadOnly",
        "steps",
        "forbiddenPatternsAbsent"
      ],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "exists": {
          "const": true
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "nodeVersion": {
          "enum": [
            "22",
            "24"
          ]
        },
        "permissionsReadOnly": {
          "const": true
        },
        "steps": {
          "type": "array",
          "minItems": 8,
          "items": {
            "$ref": "#/$defs/ReleaseCiStepV1"
          }
        },
        "forbiddenPatternsAbsent": {
          "const": true
        }
      }
    },
    "ReleaseCiPipelineV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "workflows",
        "orderPolicy",
        "promotionPolicy"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "ReleaseCiPipelineV1"
        },
        "schemaVersion": {
          "const": 1
        },
        "workflows": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/ReleaseCiWorkflowV1"
          }
        },
        "orderPolicy": {
          "type": "object",
          "required": [
            "productBoundaryBeforeCapability",
            "closureReadinessBeforeCapability",
            "capabilityBeforeTopHarness",
            "releaseCiPipelineBeforeEvidenceIndex",
            "releaseEvidenceIndexBeforeTopHarness",
            "topHarnessBeforeCheck",
            "diffGuardLast"
          ],
          "additionalProperties": false,
          "properties": {
            "productBoundaryBeforeCapability": {
              "const": true
            },
            "closureReadinessBeforeCapability": {
              "const": true
            },
            "capabilityBeforeTopHarness": {
              "const": true
            },
            "releaseCiPipelineBeforeEvidenceIndex": {
              "const": true
            },
            "releaseEvidenceIndexBeforeTopHarness": {
              "const": true
            },
            "topHarnessBeforeCheck": {
              "const": true
            },
            "diffGuardLast": {
              "const": true
            }
          }
        },
        "promotionPolicy": {
          "type": "object",
          "required": [
            "mode",
            "noLiveProviderSecretDependency",
            "repiCommandOnly",
            "noPiTakeover",
            "noNarrativeOnlyRelease"
          ],
          "additionalProperties": false,
          "properties": {
            "mode": {
              "const": "release_ci_pipeline_readiness"
            },
            "noLiveProviderSecretDependency": {
              "const": true
            },
            "repiCommandOnly": {
              "const": true
            },
            "noPiTakeover": {
              "const": true
            },
            "noNarrativeOnlyRelease": {
              "const": true
            }
          }
        }
      }
    },
    "ReleaseCiPipelineNegativeCaseV1": {
      "type": "object",
      "required": [
        "id",
        "mutates",
        "expect",
        "mustReject"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "enum": [
            "missing-product-boundary-gate",
            "capability-before-closure-readiness",
            "missing-capability-release-bundle",
            "missing-no-diff-guard",
            "live-provider-secret-required",
            "pi-command-takeover",
            "repository-check-before-top-harness"
          ]
        },
        "mutates": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "expect": {
          "const": "fail"
        },
        "mustReject": {
          "const": true
        }
      }
    },
    "ReleaseCiPipelineGateV1": {
      "type": "object",
      "required": [
        "kind",
        "schemaVersion",
        "generatedAt",
        "ReleaseCiPipelineGateV1",
        "requiredGates",
        "pipeline",
        "negativeCases",
        "invariants"
      ],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "ReleaseCiPipelineGateV1"
        },
        "schemaVersion": {
          "const": 1
        },
        "generatedAt": {
          "type": "string"
        },
        "ReleaseCiPipelineGateV1": {
          "const": true
        },
        "requiredGates": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "string"
          }
        },
        "pipeline": {
          "$ref": "#/$defs/ReleaseCiPipelineV1"
        },
        "negativeCases": {
          "type": "array",
          "minItems": 7,
          "items": {
            "$ref": "#/$defs/ReleaseCiPipelineNegativeCaseV1"
          }
        },
        "invariants": {
          "type": "array",
          "minItems": 8,
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "x-repiInvariants": [
    "ci_uses_repi_command_not_pi_takeover",
    "ci_installs_with_ignore_scripts",
    "product_boundary_before_capability_claim",
    "closure_readiness_before_capability_release",
    "capability_release_before_top_harness",
    "top_harness_before_repository_check",
    "no_generated_diff_after_checks",
    "ci_no_live_provider_or_secret_dependency",
    "release_ci_pipeline_before_evidence_index",
    "release_evidence_index_before_top_harness",
    "runtime_adapter_execution_before_top_harness"
  ]
}
