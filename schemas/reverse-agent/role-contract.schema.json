{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/role-contract.schema.json",
  "title": "REPI Role Contract",
  "type": "object",
  "required": ["contractVersion", "runId", "evidenceOrder", "roles", "ledgerPolicy", "conflictPolicy", "claimGatePolicy"],
  "properties": {
    "contractVersion": { "type": "integer", "minimum": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "evidenceOrder": {
      "type": "array",
      "items": { "type": "string" },
      "contains": { "const": "same_window_live" }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "mustEmit", "allowedClaimKinds", "forbiddenClaimKinds", "handoffTargets", "evidenceContract"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "mustEmit": { "type": "array", "items": { "type": "string" } },
          "allowedClaimKinds": { "type": "array", "items": { "type": "string" } },
          "forbiddenClaimKinds": { "type": "array", "items": { "type": "string" } },
          "handoffTargets": { "type": "array", "items": { "type": "string" } },
          "evidenceContract": { "type": "array", "items": { "type": "string" } },
          "mustValidateClaimKinds": { "type": "array", "items": { "type": "string" } },
          "mustChallengeScopes": { "type": "array", "items": { "type": "string" } },
          "mustResolve": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "ledgerPolicy": {
      "type": "object",
      "required": ["appendOnly", "prevHash", "eventHash", "requiredEventTypes"],
      "properties": {
        "appendOnly": { "const": true },
        "prevHash": { "type": "string" },
        "eventHash": { "type": "string" },
        "requiredEventTypes": {
          "type": "array",
          "items": { "enum": ["artifact_handoff", "claim", "validation", "challenge", "resolution"] }
        }
      },
      "additionalProperties": true
    },
    "conflictPolicy": {
      "type": "object",
      "required": ["tableRequired", "evidenceOrder", "unresolvedBlocksFinal"],
      "properties": {
        "tableRequired": { "const": true },
        "evidenceOrder": { "type": "array", "items": { "type": "string" } },
        "unresolvedBlocksFinal": { "const": true }
      },
      "additionalProperties": true
    },
    "claimGatePolicy": {
      "type": "object",
      "required": ["provenRequiresArtifactSha256", "provenRequiresJsonQuery", "finalPassRequiresVerifier", "unresolvedChallengeBlocks"],
      "properties": {
        "provenRequiresArtifactSha256": { "const": true },
        "provenRequiresJsonQuery": { "const": true },
        "finalPassRequiresVerifier": { "const": true },
        "unresolvedChallengeBlocks": { "const": true }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
