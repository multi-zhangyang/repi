{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/failure-repair-contract.schema.json",
  "title": "REPI Failure and Repair Contracts",
  "type": "object",
  "x-repiStrictFixture": "fixtures/reverse-agent/failure-repair-strict.fixture.json",
  "x-repiDedupWindow": {
    "mode": "deterministic-batch-signature-window",
    "failureKey": ["source", "scope", "signature", "attempt"],
    "repairKey": ["repairId"],
    "budgetKey": ["signature", "retryBudget.retryKey", "budget.retryKey"],
    "rejects": ["duplicate_failure_signature_attempt", "duplicate_repair_id", "failure_repair_signature_mismatch", "exhausted_unpaused_retry"]
  },
  "x-repiTerminalRules": {
    "exhaustedFailureBudget": "status=exhausted requires remainingAttempts=0 or attempt>=maxAttempts",
    "exhaustedRepairRetry": "linked exhausted failures must not continue with unpaused rerun/retry repairs"
  },
  "x-repiInvariants": [
    "strict_additional_properties_false_for_failure_and_repair",
    "local_strict_fixture_must_pass",
    "deterministic_duplicate_signature_attempt_rejected",
    "same_signature_shares_retry_budget",
    "exhausted_status_stops_blind_retry",
    "exhausted_failure_requires_remaining_zero_or_attempt_gte_maxAttempts",
    "linked_exhausted_failure_cannot_unpause_rerun_or_retry",
    "failedGates_map_to_repair_queue_item",
    "per_attempt_stdout_stderr_or_artifact_hashes_preserved",
    "autofix_requires_baseline_allowlist_regression_gate_and_rollback_criteria"
  ],
  "$defs": {
    "HexDigest8To64": {
      "type": "string",
      "pattern": "^[a-f0-9]{8,64}$"
    },
    "Sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "EvidenceWriteback": {
      "type": "object",
      "required": ["failureLedgerPath", "repairQueuePath", "appendOnly"],
      "properties": {
        "failureLedgerPath": { "type": "string", "minLength": 1 },
        "repairQueuePath": { "type": "string", "minLength": 1 },
        "appendOnly": { "const": true },
        "mode": { "type": "string" }
      },
      "additionalProperties": false
    },
    "BlockedCondition": {
      "type": "object",
      "required": ["reason", "unblock"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "unblock": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "Artifact": {
      "type": "object",
      "required": ["path", "sha256", "tier"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/Sha256" },
        "tier": { "enum": ["same_window_live", "runtime_artifact", "network", "served_asset", "process_config", "persisted_state"] },
        "bytes": { "type": "integer", "minimum": 0 },
        "mtime": { "type": "string", "format": "date-time" },
        "exists": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ArtifactHash": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/Sha256" }
      },
      "additionalProperties": false
    },
    "RetryBudget": {
      "type": "object",
      "required": ["retryKey", "remainingAttempts", "exhaustedAction"],
      "properties": {
        "retryKey": { "$ref": "#/$defs/HexDigest8To64" },
        "remainingAttempts": { "type": "integer", "minimum": 0 },
        "exhaustedAction": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "Rollback": {
      "type": "object",
      "required": ["required", "baseline", "allowlist", "criteria", "restored"],
      "properties": {
        "required": { "type": "boolean" },
        "baseline": { "type": "string", "minLength": 1 },
        "allowlist": { "type": "array", "items": { "type": "string" } },
        "criteria": { "type": "array", "items": { "type": "string" } },
        "restored": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "Preconditions": {
      "type": "object",
      "required": ["liveAllowed", "providerAllowed", "requiredSecrets"],
      "properties": {
        "liveAllowed": { "type": "boolean" },
        "providerAllowed": { "type": "boolean" },
        "requiredSecrets": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "RollbackCriteria": {
      "type": "object",
      "required": ["baseline", "mustRestore", "verificationCommand"],
      "properties": {
        "baseline": { "type": "string", "minLength": 1 },
        "mustRestore": { "type": "array", "items": { "type": "string" } },
        "verificationCommand": { "type": "string" }
      },
      "additionalProperties": false
    },
    "FailureLedgerEventV1": {
      "title": "REPI Failure Ledger Event V1",
      "type": "object",
      "required": [
        "id",
        "ts",
        "source",
        "scope",
        "category",
        "signature",
        "attempt",
        "maxAttempts",
        "status",
        "failedGates",
        "artifacts",
        "artifactHashes",
        "repairId",
        "budget",
        "retryBudget",
        "evidenceWriteback",
        "blockedConditions",
        "rollback"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^fail:[A-Za-z0-9_.:-]+:[a-f0-9]{8,64}(?::[0-9]+)?$" },
        "ts": { "type": "string", "format": "date-time" },
        "source": { "type": "string", "minLength": 1 },
        "scope": { "type": "string", "minLength": 1 },
        "category": {
          "enum": ["artifact_stale", "runtime_failed", "tool_missing", "contract_gap", "same_window_gap", "same_window_xhs_gap", "same_window_douyin_gap", "same_window_bilibili_gap", "platform_claim_gap"]
        },
        "signature": { "$ref": "#/$defs/HexDigest8To64" },
        "attempt": { "type": "integer", "minimum": 0 },
        "maxAttempts": { "type": "integer", "minimum": 0 },
        "status": { "enum": ["failed", "retrying", "repair_queued", "repaired", "exhausted", "rolled_back", "escalated", "blocked"] },
        "failedGates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/Artifact" } },
        "artifactHashes": { "type": "array", "items": { "$ref": "#/$defs/ArtifactHash" } },
        "repairId": { "type": "string", "pattern": "^repair:[A-Za-z0-9_.:-]+:[a-f0-9]{8,64}$" },
        "budget": { "$ref": "#/$defs/RetryBudget" },
        "retryBudget": { "$ref": "#/$defs/RetryBudget" },
        "evidenceWriteback": { "$ref": "#/$defs/EvidenceWriteback" },
        "blockedConditions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/BlockedCondition" } },
        "rollback": { "$ref": "#/$defs/Rollback" }
      },
      "additionalProperties": false,
      "x-repiInvariants": [
        "strict_additional_properties_false_for_failure_and_repair",
        "same_signature_shares_retry_budget",
        "exhausted_status_stops_blind_retry",
        "exhausted_failure_requires_remaining_zero_or_attempt_gte_maxAttempts",
        "failedGates_map_to_repair_queue_item",
        "per_attempt_stdout_stderr_or_artifact_hashes_preserved",
        "autofix_requires_baseline_allowlist_regression_gate_and_rollback_criteria"
      ]
    },
    "RepairQueueItemV1": {
      "title": "REPI Repair Queue Item V1",
      "type": "object",
      "required": [
        "repairId",
        "fromFailureId",
        "signature",
        "scope",
        "action",
        "commands",
        "expectedArtifacts",
        "expectedGates",
        "preconditions",
        "paused",
        "allowlist",
        "rollbackCriteria",
        "repairAction",
        "blockedConditions",
        "evidenceWriteback",
        "regressionGates"
      ],
      "properties": {
        "repairId": { "type": "string", "pattern": "^repair:[A-Za-z0-9_.:-]+:[a-f0-9]{8,64}$" },
        "fromFailureId": { "type": "string", "pattern": "^fail:[A-Za-z0-9_.:-]+:[a-f0-9]{8,64}(?::[0-9]+)?$" },
        "signature": { "$ref": "#/$defs/HexDigest8To64" },
        "scope": { "type": "string", "minLength": 1 },
        "action": { "enum": ["rerun", "replace-command", "recapture-evidence", "refresh-context", "escalate", "rollback"] },
        "repairAction": { "enum": ["rerun", "replace-command", "recapture-evidence", "refresh-context", "escalate", "rollback"] },
        "commands": { "type": "array", "items": { "type": "string" } },
        "expectedArtifacts": { "type": "array", "items": { "type": "string" } },
        "expectedGates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "preconditions": { "$ref": "#/$defs/Preconditions" },
        "paused": { "type": "boolean" },
        "allowlist": { "type": "array", "items": { "type": "string" } },
        "rollbackCriteria": { "$ref": "#/$defs/RollbackCriteria" },
        "blockedConditions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/BlockedCondition" } },
        "evidenceWriteback": { "$ref": "#/$defs/EvidenceWriteback" },
        "regressionGates": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "note": { "type": "string" }
      },
      "additionalProperties": false,
      "x-repiInvariants": [
        "strict_additional_properties_false_for_failure_and_repair",
        "paused_true_for_live_or_provider_dependent_repairs",
        "commands_are_not_executed_by_static_gate",
        "expectedGates_must_bind_to_failedGates",
        "repair_completion_requires_regressionGates_pass",
        "linked_exhausted_failure_cannot_unpause_rerun_or_retry",
        "deterministic_duplicate_signature_attempt_rejected"
      ]
    }
  },
  "oneOf": [{ "$ref": "#/$defs/FailureLedgerEventV1" }, { "$ref": "#/$defs/RepairQueueItemV1" }]
}
