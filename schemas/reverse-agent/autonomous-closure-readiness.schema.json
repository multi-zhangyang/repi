{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://repi.local/schemas/reverse-agent/autonomous-closure-readiness.schema.json",
  "title": "AutonomousClosureReadinessGateV1",
  "description": "autonomous_closure_readiness_gate: every AutonomousHardeningGapLedgerV1 closureGate must be executable, package-addressable, top-harness-child-gated, autonomy-control-plane-visible, documented, and strict --no-write green before a gap can move beyond ready_for_live.",
  "type": "object",
  "required": ["kind", "schemaVersion", "generatedAt", "AutonomousClosureReadinessGateV1", "requiredGates", "readinessMatrix", "negativeCases", "invariants"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "AutonomousClosureReadinessGateV1" },
    "schemaVersion": { "const": 1 },
    "generatedAt": { "type": "string" },
    "AutonomousClosureReadinessGateV1": { "const": true },
    "requiredGates": {
      "type": "array",
      "minItems": 8,
      "items": {
        "enum": [
          "closure_gate_present_in_gap_ledger",
          "closure_gate_package_script_present",
          "closure_gate_script_exists",
          "closure_gate_top_harness_child_gate",
          "closure_gate_autonomy_contract_present",
          "closure_gate_docs_present",
          "closure_gate_strict_no_write_passes",
          "top_autonomous_false_until_closed"
        ]
      }
    },
    "readinessMatrix": { "$ref": "#/$defs/AutonomousClosureReadinessMatrixV1" },
    "negativeCases": {
      "type": "array",
      "minItems": 7,
      "items": { "$ref": "#/$defs/AutonomousClosureReadinessNegativeCaseV1" }
    },
    "invariants": {
      "type": "array",
      "minItems": 8,
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "AutonomousClosureReadinessMatrixV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "sourceLedger", "summary", "closureRows", "promotionPolicy"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "AutonomousClosureReadinessMatrixV1" },
        "schemaVersion": { "const": 1 },
        "sourceLedger": {
          "type": "object",
          "required": ["kind", "gapCount", "closureGateCount", "gapHash"],
          "additionalProperties": false,
          "properties": {
            "kind": { "const": "AutonomousHardeningGapLedgerV1" },
            "gapCount": { "type": "integer", "minimum": 1 },
            "closureGateCount": { "type": "integer", "minimum": 1 },
            "gapHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          }
        },
        "summary": {
          "type": "object",
          "required": ["gapCount", "closureGateCount", "readyRows", "closedRows", "failedRows", "allClosureGatesExecutable", "allClosureGatesHarnessed", "topAutonomousDefinition"],
          "additionalProperties": false,
          "properties": {
            "gapCount": { "type": "integer", "minimum": 1 },
            "closureGateCount": { "type": "integer", "minimum": 1 },
            "readyRows": { "type": "integer", "minimum": 0 },
            "closedRows": { "type": "integer", "minimum": 0 },
            "failedRows": { "type": "integer", "minimum": 0 },
            "allClosureGatesExecutable": { "type": "boolean" },
            "allClosureGatesHarnessed": { "type": "boolean" },
            "topAutonomousDefinition": { "type": "boolean" }
          }
        },
        "closureRows": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/AutonomousClosureReadinessRowV1" }
        },
        "promotionPolicy": {
          "type": "object",
          "required": ["mode", "topAutonomousDefinitionFalseUntilClosed", "readyForLiveDoesNotEqualClosed", "closedRequiresArtifactBackedRows"],
          "additionalProperties": false,
          "properties": {
            "mode": { "const": "strict_closure_gate_readiness" },
            "topAutonomousDefinitionFalseUntilClosed": { "const": true },
            "readyForLiveDoesNotEqualClosed": { "const": true },
            "closedRequiresArtifactBackedRows": { "const": true }
          }
        }
      }
    },
    "AutonomousClosureReadinessRowV1": {
      "type": "object",
      "required": [
        "gapId",
        "pillar",
        "status",
        "closureGate",
        "scriptPath",
        "npmScript",
        "packageScriptPresent",
        "gateScriptExists",
        "topHarnessChildGatePresent",
        "autonomyContractPresent",
        "docsPresent",
        "strictNoWritePass",
        "acceptanceCriteriaBacked",
        "readyForLive",
        "artifactBackedClosure",
        "closureEvidenceRefs",
        "evidenceRefs",
        "notClosedReason"
      ],
      "additionalProperties": false,
      "properties": {
        "gapId": { "type": "string", "minLength": 1 },
        "pillar": { "enum": ["parallel_scheduling", "long_context_compaction", "failure_self_repair", "automatic_division_validation"] },
        "status": { "enum": ["open", "partially_wired", "ready_for_live", "blocked", "closed"] },
        "closureGate": { "type": "string", "pattern": "^gate:[a-z0-9-]+$" },
        "scriptPath": { "type": "string", "pattern": "^scripts/reverse-agent/.+\\.mjs$" },
        "npmScript": { "type": "string", "minLength": 1 },
        "packageScriptPresent": { "type": "boolean" },
        "gateScriptExists": { "type": "boolean" },
        "topHarnessChildGatePresent": { "type": "boolean" },
        "autonomyContractPresent": { "type": "boolean" },
        "docsPresent": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "strictNoWritePass": { "type": "boolean" },
        "acceptanceCriteriaBacked": { "type": "boolean" },
        "readyForLive": { "type": "boolean" },
        "artifactBackedClosure": { "type": "boolean" },
        "closureEvidenceRefs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "evidenceRefs": {
          "type": "array",
          "minItems": 4,
          "items": { "type": "string", "minLength": 1 }
        },
        "notClosedReason": { "type": "string" }
      }
    },
    "AutonomousClosureReadinessNegativeCaseV1": {
      "type": "object",
      "required": ["id", "mutates", "expect", "mustReject"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "enum": [
            "missing-package-script",
            "missing-top-harness-child-gate",
            "missing-autonomy-contract",
            "missing-docs",
            "closure-gate-run-failed",
            "top-autonomous-true-with-ready-gaps",
            "closed-gap-without-artifact-backed-row"
          ]
        },
        "mutates": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "expect": { "const": "fail" },
        "mustReject": { "const": true }
      }
    },
    "AutonomousClosureReadinessGateV1": {
      "type": "object",
      "required": ["kind", "schemaVersion", "generatedAt", "AutonomousClosureReadinessGateV1", "requiredGates", "readinessMatrix", "negativeCases", "invariants"],
      "additionalProperties": false,
      "properties": {
        "kind": { "const": "AutonomousClosureReadinessGateV1" },
        "schemaVersion": { "const": 1 },
        "generatedAt": { "type": "string" },
        "AutonomousClosureReadinessGateV1": { "const": true },
        "requiredGates": { "type": "array", "minItems": 8, "items": { "type": "string" } },
        "readinessMatrix": { "$ref": "#/$defs/AutonomousClosureReadinessMatrixV1" },
        "negativeCases": { "type": "array", "minItems": 7, "items": { "$ref": "#/$defs/AutonomousClosureReadinessNegativeCaseV1" } },
        "invariants": { "type": "array", "minItems": 8, "items": { "type": "string" } }
      }
    }
  },
  "x-repiInvariants": [
    "closure_gate_present_in_gap_ledger",
    "closure_gate_package_script_present",
    "closure_gate_script_exists",
    "closure_gate_top_harness_child_gate",
    "closure_gate_autonomy_contract_present",
    "closure_gate_docs_present",
    "closure_gate_strict_no_write_passes",
    "top_autonomous_false_until_closed"
  ]
}
