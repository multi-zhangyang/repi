#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then SOURCE="$DIR/$TARGET"; else SOURCE="$TARGET"; fi
done
SELF="$(readlink -f "$SOURCE" 2>/dev/null || printf '%s' "$SOURCE")"

# This repository no longer claims the `pi` command. `repi` is the Pi-RECON
# product entrypoint; `pi` should resolve to the upstream Pi installation.
IFS=':' read -r -a PATH_PARTS <<< "${PATH:-}"
for dir in "${PATH_PARTS[@]}"; do
  [ -n "$dir" ] || continue
  candidate="$dir/pi"
  [ -x "$candidate" ] || continue
  resolved="$(readlink -f "$candidate" 2>/dev/null || printf '%s' "$candidate")"
  [ "$resolved" != "$SELF" ] || continue
  exec "$candidate" "$@"
done

cat >&2 <<'MSG'
This checkout no longer owns the `pi` command.
Use `repi` for Pi-RECON, and install/keep upstream Pi separately if you need `pi`.
MSG
exit 127
