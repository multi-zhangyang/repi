#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" != /* ]]; then SOURCE="$DIR/$TARGET"; else SOURCE="$TARGET"; fi
done
ROOT="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# REPI is the independent product entrypoint. It never owns the
# upstream `pi` command and keeps all runtime state in ~/.repi/agent.
export REPI_CODING_AGENT_APP_NAME="${REPI_CODING_AGENT_APP_NAME:-repi}"
export REPI_CODING_AGENT_CONFIG_DIR="${REPI_CODING_AGENT_CONFIG_DIR:-.repi}"
export PI_CODING_AGENT_APP_NAME="${PI_CODING_AGENT_APP_NAME:-repi}"
export PI_CODING_AGENT_CONFIG_DIR="${PI_CODING_AGENT_CONFIG_DIR:-.repi}"
export REPI_CODING_AGENT_DIR="${REPI_CODING_AGENT_DIR:-${REPI_AGENT_DIR:-$HOME/.repi/agent}}"
export REPI_CODING_AGENT_SESSION_DIR="${REPI_CODING_AGENT_SESSION_DIR:-$REPI_CODING_AGENT_DIR/sessions}"
export REPI_PRIMARY=1
export REPI_PRODUCT=1
export PI_RECON_PRIMARY=1
export PI_RECON_PRODUCT=1
export REPI_SKIP_VERSION_CHECK="${REPI_SKIP_VERSION_CHECK:-1}"
export REPI_SKIP_PACKAGE_UPDATE_CHECK="${REPI_SKIP_PACKAGE_UPDATE_CHECK:-1}"
export REPI_TELEMETRY="${REPI_TELEMETRY:-0}"
export REPI_OFFLINE="${REPI_OFFLINE:-${PI_OFFLINE:-0}}"
export REPI_PRINT_PROGRESS="${REPI_PRINT_PROGRESS:-1}"
export REPI_PRINT_TIMEOUT_MS="${REPI_PRINT_TIMEOUT_MS:-210000}"
export REPI_BASH_DEFAULT_TIMEOUT_SECONDS="${REPI_BASH_DEFAULT_TIMEOUT_SECONDS:-120}"
# Compatibility for inherited upstream internals; user-facing REPI docs prefer REPI_* names.
export PI_SKIP_VERSION_CHECK="${PI_SKIP_VERSION_CHECK:-$REPI_SKIP_VERSION_CHECK}"
export PI_SKIP_PACKAGE_UPDATE_CHECK="${PI_SKIP_PACKAGE_UPDATE_CHECK:-$REPI_SKIP_PACKAGE_UPDATE_CHECK}"
export PI_TELEMETRY="${PI_TELEMETRY:-$REPI_TELEMETRY}"
export PI_OFFLINE="${PI_OFFLINE:-$REPI_OFFLINE}"
export REPI_REPO_ROOT="$ROOT"

case "${1:-}" in
  doctor)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-doctor.mjs" "$ROOT" "$@"
    ;;
  smoke)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-smoke.mjs" "$ROOT" "$@"
    ;;
  selfcheck|dogfood)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-selfcheck.mjs" "$ROOT" "$@"
    ;;
  bugreport)
    shift
    exec node "$ROOT/scripts/reverse-agent/repi-bugreport.mjs" "$ROOT" "$@"
    ;;
  swarm)
    sub="${2:-help}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      plan|run|status|merge|llm-run|run-llm|workers)
        exec node "$ROOT/scripts/reverse-agent/repi-swarm-llm-run.mjs" "$ROOT" "$sub" "$@"
        ;;
      help|--help|-h)
        exec node "$ROOT/scripts/reverse-agent/repi-swarm-llm-run.mjs" "$ROOT" --help
        ;;
      *)
        echo "Unknown repi swarm command: $sub" >&2
        echo "Run: repi swarm --help" >&2
        exit 2
        ;;
    esac
    ;;
  memory)
    sub="${2:-status}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      consolidate)
        exec node "$ROOT/scripts/reverse-agent/memory-consolidate.mjs" "$ROOT" "$@"
        ;;
      status|list|show|diff|why|forget|quarantine|doctor|export|purge)
        exec node "$ROOT/scripts/reverse-agent/memory-inspect.mjs" "$ROOT" "$sub" "$@"
        ;;
      help|--help|-h)
        cat <<'MSG'
Usage:
  repi memory status [--json]
  repi memory list [--json] [--limit N] [--all] [--query <text>]
  repi memory show <query-or-event-id> [--json]
  repi memory diff [--json] [--limit N] [--all]
  repi memory why <query-or-event-id> [--json]
  repi memory forget <query-or-event-id> [--reason <text>]
  repi memory quarantine <query-or-event-id> [--reason <text>]
  repi memory doctor [--json]
  repi memory export [--output <path>] [--full] [--json]
  repi memory purge [--dry-run|--apply] [--governed|--older-than-days N|--query <text>|--id <event-id>|--all]
  repi memory consolidate [--dry-run] [--json]
MSG
        exit 0
        ;;
      *)
        echo "Unknown repi memory command: $sub" >&2
        echo "Run: repi memory --help" >&2
        exit 2
        ;;
    esac
    ;;
  model|models)
    sub="${2:-doctor}"
    if [ "$#" -ge 2 ]; then shift 2; else shift 1; fi
    case "$sub" in
      doctor|status|list|cost|add|edit|remove|login|test|default|export|import|help|--help|-h)
        exec node "$ROOT/scripts/reverse-agent/model-inspect.mjs" "$ROOT" "$sub" "$@"
        ;;
      *)
        echo "Unknown repi model command: $sub" >&2
        echo "Run: repi model --help" >&2
        exit 2
        ;;
    esac
    ;;
esac

exec "$ROOT/node_modules/.bin/tsx" --tsconfig "$ROOT/tsconfig.json" "$ROOT/packages/coding-agent/src/cli.ts" "$@"
