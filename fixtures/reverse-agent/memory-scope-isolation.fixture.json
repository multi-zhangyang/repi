{
  "kind": "repi-memory-scope-isolation-fixture",
  "schemaVersion": 1,
  "MemoryScopeIsolationV1": true,
  "requiredGates": [
    "MemoryScopeIsolationV1",
    "scope_filter_by_mission_session_workspace_target",
    "cross_session_contamination_negative",
    "cross_workspace_contamination_blocks_injection",
    "cross_target_contamination_blocks_injection",
    "legacy_memory_scope_requires_manual_review",
    "scope_isolation_report_in_context_pack"
  ],
  "scenarios": [
    {
      "id": "same-scope-allows-injection",
      "eventScope": { "sessionId": "session-b", "workspaceRoot": "/workspace/b", "branchId": "main", "target": "https://target-b.local" },
      "currentScope": { "sessionId": "session-b", "workspaceRoot": "/workspace/b", "branchId": "main", "target": "https://target-b.local" },
      "expectedVerdict": "allow"
    },
    {
      "id": "cross-session-workspace-blocks-injection",
      "eventScope": { "sessionId": "session-a", "workspaceRoot": "/workspace/a", "branchId": "main", "target": "https://target-a.local" },
      "currentScope": { "sessionId": "session-b", "workspaceRoot": "/workspace/b", "branchId": "main", "target": "https://target-b.local" },
      "expectedVerdict": "block",
      "mustHaveReasons": ["cross_session_contamination", "cross_workspace_contamination", "cross_target_contamination"]
    },
    {
      "id": "legacy-scope-warns-manual-review",
      "eventScope": null,
      "currentScope": { "sessionId": "session-b", "workspaceRoot": "/workspace/b", "branchId": "main" },
      "expectedVerdict": "warn",
      "mustHaveReasons": ["legacy_memory_scope_missing"]
    }
  ]
}
