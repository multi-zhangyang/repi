{
  "kind": "repi-knowledge-scope-isolation-fixture",
  "schemaVersion": 1,
  "KnowledgeScopeIsolationV1": true,
  "requiredGates": [
    "KnowledgeScopeIsolationV1",
    "MemoryScopeIsolationV1",
    "scope_filter_by_mission_session_workspace_target",
    "knowledge_graph_scope_filter_blocks_quarantined_artifacts",
    "knowledge_graph_command_hints_exclude_scope_blocked_sources",
    "knowledge_scope_isolation_report_in_artifact"
  ],
  "scenarios": [
    {
      "id": "blocked-artifact-excluded-from-command-hints",
      "sourceArtifact": "/workspace/a/evidence/runs/blocked-target-a.md",
      "expectedVerdict": "block",
      "mustNotAppearIn": ["commandStrategyHints", "similarityIndex"],
      "mustHaveReasons": ["cross_workspace_contamination", "cross_target_contamination"]
    },
    {
      "id": "allowed-artifact-remains-queryable",
      "sourceArtifact": "/workspace/b/evidence/runs/allowed-target-b.md",
      "expectedVerdict": "allow",
      "mustAppearIn": ["commandStrategyHints", "similarityIndex"]
    },
    {
      "id": "scope-report-embedded-in-knowledge-graph",
      "mustHaveFields": ["knowledgeScopeIsolation", "quarantinedSourceArtifacts", "sourceRows", "requiredGates"],
      "mustHaveMarkers": ["KnowledgeScopeIsolationV1", "MemoryScopeIsolationV1", "scope_filter_by_mission_session_workspace_target"]
    }
  ]
}
