{
  "kind": "repi-live-conflict-arbitration-matrix-fixture",
  "schemaVersion": 1,
  "description": "LiveConflictArbitrationMatrixGateV1 fixture coverage for cross-runtime claim conflict arbitration.",
  "requiredGates": [
    "LiveConflictArbitrationMatrixGateV1",
    "source_coverage_all_runtimes",
    "multi_claim_topic_conflict_matrix",
    "winner_evidence_json_query_verifier",
    "loser_downgrade_blocks_promotion",
    "orchestration_success_separate_from_platform_claim",
    "synthesizer_summary_parsed_to_structured_rows",
    "claim_ledger_refs_hash_chain_quality",
    "provider_backed_same_window_multi_worker_conflict_table",
    "long_run_synthesizer_topic_parse_matrix",
    "provider_backed_long_window_conflict_matrix",
    "synthesizer_extended_ten_topic_parse_matrix",
    "provider_backed_eight_window_conflict_matrix",
    "synthesizer_extended_topic_parse_matrix"
  ],
  "requiredSources": [
    "agent-dogfood",
    "re_swarm",
    "compound-frontier",
    "provider-worker"
  ],
  "conflictTopics": [
    "orders ownership replay result",
    "signed API replay proof",
    "provider timeout cancellation and repair boundary",
    "API abuse-window rate-limit proof",
    "provider-backed same-window multi-worker conflict table",
    "long-run synthesizer topic parse matrix",
    "provider-backed long-window conflict matrix",
    "extended synthesizer topic parse matrix",
    "session token scope proof",
    "API idempotency duplicate replay proof"
  ],
  "positiveRequirements": [
    "every conflict row has at least two claimIds and a resolved winnerClaimId",
    "winner evidence refs must bind to artifact sha256 and JSON query verifierPass",
    "loser downgrade rows must set blockedPromotion=true and appear in blockedClaims",
    "orchestrationStatus=pass does not imply platformClaimStatus=proven",
    "every source manifest carries runtimeManifestPath, structuredClaimMergePath, claimLedgerPath and hash-chain quality",
    "provider-backed same-window conflict table must include at least two provider worker ids and provider-worker source claims",
    "long-run synthesizer topic parse matrix must cover authz, JS replay, provider timeout, API rate-limit, session token scope, and API idempotency replay topics",
    "narrative-only synthesizer rows must remain blocked and must not promote final claims",
    "provider-backed long-window conflict matrix must cover at least two windows, at least two provider workers per window, at least five provider-backed claims, request log refs, runtime manifest refs and env-ref-only secret handling",
    "extended synthesizer topic parse matrix must cover authz, JS replay, provider timeout, API rate-limit, session token scope and API idempotency replay topics",
    "provider-backed long-window rows must reject literal secrets and must keep loser claims blocked across windows",
    "provider-backed long-window conflict matrix covers eight provider-backed windows",
    "extended synthesizer topic parse matrix covers ten structured topics with final winners only"
  ],
  "negativeCases": [
    {
      "id": "missing-winner-evidence",
      "mutates": "conflictRows[0].winningEvidenceRefs",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "loser-promoted",
      "mutates": "promotionGate.finalClaims += loser claim",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "orchestration-implies-platform-pass",
      "mutates": "plan-only orchestration row promoted as platform claim",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "missing-source-coverage",
      "mutates": "sources remove provider-worker",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "narrative-only-synthesizer-promoted",
      "mutates": "synthesizerRows narrativeOnly=true with final claim",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "claim-ledger-ref-missing",
      "mutates": "source claimLedgerPath missing",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "unresolved-conflict",
      "mutates": "conflictRows[0].status=unresolved",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "final-without-json-query",
      "mutates": "finalClaims[0].artifactRefs[0].jsonQuery",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "provider-backed-conflict-single-worker",
      "mutates": "providerBackedConflictTable[0].providerWorkerIds keeps only one worker",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "synthesizer-topic-parse-missing",
      "mutates": "synthesizerTopicParseMatrix.topicRows removes api:rate-limit:abuse-window",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "same-window-conflict-without-provider-worker",
      "mutates": "provider-backed same-window conflict drops provider-worker source/claims",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "long-window-conflict-too-short",
      "mutates": "providerBackedLongWindowConflictMatrix.windows keeps only one window",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "extended-topic-parse-missing",
      "mutates": "extendedSynthesizerTopicParseMatrix.topicRows removes api:idempotency:replay",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "provider-window-secret-leak",
      "mutates": "providerBackedLongWindowConflictMatrix.windows requestLogRefs contains literal token-like secret",
      "expect": "reject",
      "mustNotPromote": true
    }
  ],
  "promotionPolicy": {
    "mode": "strict_live_conflict_arbitration",
    "requiresSourceCoverage": true,
    "requiresWinnerEvidenceJsonQueryVerifier": true,
    "requiresLoserDowngradeBlockedPromotion": true,
    "requiresOrchestrationPlatformSplit": true,
    "requiresClaimLedgerHashChainQuality": true,
    "requiresProviderBackedSameWindowMultiWorkerConflictTable": true,
    "requiresLongRunSynthesizerTopicParseMatrix": true,
    "requiresProviderBackedLongWindowConflictMatrix": true,
    "requiresExtendedSynthesizerTopicParseMatrix": true,
    "requiresProviderBackedEightWindowConflictMatrix": true,
    "requiresExtendedTenTopicParseMatrix": true
  },
  "invariants": [
    "live_conflict_arbitration_matrix_gate",
    "source_coverage_all_runtimes",
    "multi_claim_topic_conflict_matrix",
    "winner_evidence_json_query_verifier",
    "loser_downgrade_blocks_promotion",
    "orchestration_success_separate_from_platform_claim",
    "synthesizer_summary_parsed_to_structured_rows",
    "claim_ledger_refs_hash_chain_quality",
    "provider_backed_same_window_multi_worker_conflict_table",
    "long_run_synthesizer_topic_parse_matrix",
    "provider_backed_long_window_conflict_matrix",
    "synthesizer_extended_ten_topic_parse_matrix",
    "provider_backed_eight_window_conflict_matrix",
    "synthesizer_extended_topic_parse_matrix"
  ]
}
