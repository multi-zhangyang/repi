{
  "kind": "repi-failure-signature-priority-fixture",
  "schemaVersion": 1,
  "FailureSignaturePriorityGateV1": true,
  "requiredGates": [
    "FailureSignaturePriorityGateV1",
    "proof_loop_failure_signature_priority",
    "knowledge_graph_failure_signature_priority",
    "runtime_failure_ledger_preempts_blind_retry",
    "repair_queue_ready_command_required",
    "target_scoped_failure_signature_priority"
  ],
  "invariants": [
    "failure_signature_priority_gate",
    "proof_loop_failure_signature_priority",
    "knowledge_graph_failure_signature_priority",
    "runtime_failure_ledger_preempts_blind_retry",
    "repair_queue_ready_command_required",
    "target_scoped_failure_signature_priority",
    "missing_repair_command_is_not_ready",
    "unrelated_target_failure_does_not_leak"
  ],
  "scenarios": [
    {
      "id": "exhausted-failure-preempts-operator-feedback",
      "inputLedger": {
        "target": "https://failure-priority.target.local/app",
        "failureStatuses": ["exhausted"],
        "repairQueueCommands": ["re_autofix plan https://failure-priority.target.local/app"]
      },
      "expectedProofLoop": [
        "failure_signature_priority status=exhausted",
        "repair_ready=true",
        "next=re_autofix plan https://failure-priority.target.local/app"
      ],
      "expectedKnowledgeGraph": ["failure_signature_priority=1", "failure_signature_exhausted=1"],
      "mustNotContain": ["blind retry before repair"]
    },
    {
      "id": "repeated-failure-promotes-repair-command",
      "inputLedger": {
        "target": "https://failure-priority.target.local/app",
        "failureStatuses": ["repair_queued", "repair_queued"],
        "repairQueueCommands": ["re_supervisor repair https://failure-priority.target.local/app"]
      },
      "expectedProofLoop": [
        "failure_signature_priority status=repair_queued",
        "repeats=2",
        "next=re_supervisor repair https://failure-priority.target.local/app"
      ],
      "expectedKnowledgeGraph": ["failure_signature_repairs=", "re_supervisor repair https://failure-priority.target.local/app"],
      "mustNotContain": ["ignore repeated signature"]
    },
    {
      "id": "unrelated-target-failure-does-not-leak",
      "inputLedger": {
        "target": "https://failure-priority.target.local/app",
        "failureStatuses": ["exhausted"],
        "repairQueueCommands": ["re_autofix plan https://unrelated-failure.local/app"]
      },
      "expectedProofLoop": ["target_scoped_failure_signature_priority"],
      "expectedKnowledgeGraph": ["target_scoped_failure_signature_priority"],
      "mustNotContain": ["UNRELATED_LEAK_DO_NOT_USE", "https://unrelated-failure.local/app"]
    },
    {
      "id": "missing-repair-command-is-not-ready",
      "inputLedger": {
        "target": "https://failure-priority.target.local/app",
        "failureStatuses": ["repair_queued"],
        "repairQueueCommands": []
      },
      "expectedProofLoop": ["failure_signature_repair_queue", "ready=false", "commands=missing"],
      "expectedKnowledgeGraph": ["failure_signature_repair_queue"],
      "mustNotContain": ["ready=true commands=missing", "next=missing"]
    }
  ]
}
