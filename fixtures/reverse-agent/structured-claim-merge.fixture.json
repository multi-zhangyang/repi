{
  "kind": "repi-structured-claim-merge-fixture",
  "schemaVersion": 1,
  "artifacts": [
    {
      "path": ".repi-harness/evidence/claims/authz-strong.json",
      "content": "{\n  \"claimId\": \"claim-authz-strong\",\n  \"workerId\": \"worker-authz-verifier\",\n  \"verifier\": \"pass\",\n  \"ownershipReplay\": \"blocked_cross_principal\",\n  \"status\": \"proven\",\n  \"principalMatrix\": [\n    \"alice\",\n    \"bob\"\n  ],\n  \"evidenceQuality\": \"strong\"\n}",
      "sha256": "a75cf805b98ab1f05219e03816e375b7fe9207774e88892c0dd28adc1941339e"
    },
    {
      "path": ".repi-harness/evidence/claims/authz-weak.json",
      "content": "{\n  \"claimId\": \"claim-authz-weak\",\n  \"workerId\": \"worker-authz-mapper\",\n  \"verifier\": \"weak\",\n  \"ownershipReplay\": \"not_checked\",\n  \"status\": \"gap\",\n  \"principalMatrix\": [\n    \"alice\"\n  ],\n  \"evidenceQuality\": \"weak\"\n}",
      "sha256": "7652207ebbb8f24c93525e701271c0aefe2f576fe3670d10fd84475e1ff32d35"
    },
    {
      "path": ".repi-harness/evidence/claims/js-signer-anchor.json",
      "content": "{\n  \"claimId\": \"claim-js-signer-anchor\",\n  \"workerId\": \"worker-js-signer\",\n  \"verifier\": \"pass\",\n  \"anchor\": \"signer_callsite\",\n  \"replayVerified\": false,\n  \"status\": \"anchor_only\"\n}",
      "sha256": "995bfb5a990b95d0c003c1cc7a319e19a83c0ca2b29dd680f62f5c547e116512"
    }
  ],
  "structuredClaimMerge": {
    "kind": "StructuredClaimMergeV1",
    "schemaVersion": 1,
    "mergeId": "merge-fixture-001",
    "sourcePoolId": "pool-child-001",
    "target": "https://example.test",
    "claimRows": [
      {
        "claimId": "claim-authz-strong",
        "workerId": "worker-authz-verifier",
        "mergeKey": "authz:orders:ownership",
        "status": "proven",
        "statement": "Cross-principal replay blocks access to another user order.",
        "artifactRefs": [
          {
            "artifactId": "authz-strong",
            "path": ".repi-harness/evidence/claims/authz-strong.json",
            "sha256": "a75cf805b98ab1f05219e03816e375b7fe9207774e88892c0dd28adc1941339e",
            "jsonQuery": "$.ownershipReplay",
            "op": "==",
            "expected": "blocked_cross_principal",
            "verifierPass": true
          },
          {
            "artifactId": "authz-strong-status",
            "path": ".repi-harness/evidence/claims/authz-strong.json",
            "sha256": "a75cf805b98ab1f05219e03816e375b7fe9207774e88892c0dd28adc1941339e",
            "jsonQuery": "$.verifier",
            "op": "==",
            "expected": "pass",
            "verifierPass": true
          }
        ],
        "challenges": [
          {
            "challengeId": "challenge-authz-principal-swap",
            "status": "resolved",
            "resolution": "principal matrix and replay artifact prove negative access"
          }
        ]
      },
      {
        "claimId": "claim-authz-weak",
        "workerId": "worker-authz-mapper",
        "mergeKey": "authz:orders:ownership",
        "status": "gap",
        "statement": "Mapper observed orders route but did not replay cross-principal ownership.",
        "artifactRefs": [
          {
            "artifactId": "authz-weak",
            "path": ".repi-harness/evidence/claims/authz-weak.json",
            "sha256": "7652207ebbb8f24c93525e701271c0aefe2f576fe3670d10fd84475e1ff32d35",
            "jsonQuery": "$.ownershipReplay",
            "op": "==",
            "expected": "not_checked",
            "verifierPass": false
          }
        ],
        "challenges": [
          {
            "challengeId": "challenge-missing-replay",
            "status": "resolved",
            "resolution": "downgraded to gap"
          }
        ]
      },
      {
        "claimId": "claim-js-signer-anchor",
        "workerId": "worker-js-signer",
        "mergeKey": "js:signer:anchor",
        "status": "gap",
        "statement": "Signer callsite anchor found but signed API replay not verified.",
        "artifactRefs": [
          {
            "artifactId": "js-signer-anchor",
            "path": ".repi-harness/evidence/claims/js-signer-anchor.json",
            "sha256": "995bfb5a990b95d0c003c1cc7a319e19a83c0ca2b29dd680f62f5c547e116512",
            "jsonQuery": "$.anchor",
            "op": "==",
            "expected": "signer_callsite",
            "verifierPass": true
          }
        ],
        "challenges": [
          {
            "challengeId": "challenge-replay-missing",
            "status": "resolved",
            "resolution": "not final until replayVerified true"
          }
        ]
      }
    ],
    "conflictTable": [
      {
        "conflictId": "conflict-authz-ownership",
        "claimIds": [
          "claim-authz-strong",
          "claim-authz-weak"
        ],
        "topic": "orders ownership replay result",
        "status": "resolved",
        "winnerClaimId": "claim-authz-strong",
        "winningEvidenceRefs": [
          "authz-strong",
          "authz-strong-status"
        ],
        "downgradeLosers": [
          "claim-authz-weak"
        ],
        "resolutionReason": "strong verifier replay has JSON-bound ownershipReplay=blocked_cross_principal while mapper lacks replay"
      }
    ],
    "promotionGate": {
      "mode": "strict_final_claim_promotion",
      "requiredStatuses": [
        "proven"
      ],
      "finalClaims": [
        {
          "claimId": "claim-authz-strong",
          "promotion": "final_pass",
          "reportSection": "Authorization / BOLA",
          "verifierPass": true,
          "artifactRefs": [
            {
              "artifactId": "authz-strong",
              "path": ".repi-harness/evidence/claims/authz-strong.json",
              "sha256": "a75cf805b98ab1f05219e03816e375b7fe9207774e88892c0dd28adc1941339e",
              "jsonQuery": "$.ownershipReplay",
              "op": "==",
              "expected": "blocked_cross_principal",
              "verifierPass": true
            },
            {
              "artifactId": "authz-quality",
              "path": ".repi-harness/evidence/claims/authz-strong.json",
              "sha256": "a75cf805b98ab1f05219e03816e375b7fe9207774e88892c0dd28adc1941339e",
              "jsonQuery": "$.evidenceQuality",
              "op": "==",
              "expected": "strong",
              "verifierPass": true
            }
          ]
        }
      ],
      "blockedClaims": [
        {
          "claimId": "claim-authz-weak",
          "reason": "lost resolved conflict and lacks verifier replay"
        },
        {
          "claimId": "claim-js-signer-anchor",
          "reason": "anchor only; replayVerified false"
        }
      ],
      "policies": [
        "final_pass_requires_json_query",
        "unresolved_adversary_challenge_blocks_final",
        "conflict_loser_must_be_downgraded",
        "artifact_sha256_required"
      ]
    }
  },
  "expected": {
    "mustNotHaveErrors": [
      "artifact_sha_mismatch",
      "final_pass_without_verifier_pass",
      "unresolved_adversary_challenge",
      "unresolved_conflict",
      "final_pass_claim_not_proven",
      "artifact_json_query_mismatch",
      "missing_winning_evidence"
    ]
  },
  "negativeCases": [
    {
      "id": "missing-artifact-sha",
      "mutate": "missingArtifactSha",
      "expected": {
        "mustHaveErrors": [
          "artifact_sha_mismatch"
        ]
      }
    },
    {
      "id": "verifier-fail-blocks-final",
      "mutate": "verifierFail",
      "expected": {
        "mustHaveErrors": [
          "final_pass_without_verifier_pass"
        ]
      }
    },
    {
      "id": "unresolved-challenge-blocks-final",
      "mutate": "unresolvedChallenge",
      "expected": {
        "mustHaveErrors": [
          "unresolved_adversary_challenge"
        ]
      }
    },
    {
      "id": "unresolved-conflict-blocks-final",
      "mutate": "unresolvedConflict",
      "expected": {
        "mustHaveErrors": [
          "unresolved_conflict"
        ]
      }
    },
    {
      "id": "final-gap-promoted",
      "mutate": "finalGapPromoted",
      "expected": {
        "mustHaveErrors": [
          "final_pass_claim_not_proven"
        ]
      }
    },
    {
      "id": "json-query-mismatch",
      "mutate": "jsonQueryMismatch",
      "expected": {
        "mustHaveErrors": [
          "artifact_json_query_mismatch"
        ]
      }
    },
    {
      "id": "missing-winner-evidence",
      "mutate": "missingWinnerEvidence",
      "expected": {
        "mustHaveErrors": [
          "missing_winning_evidence"
        ]
      }
    }
  ]
}
