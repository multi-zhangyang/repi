{
  "kind": "repi-worker-provider-repair-rollback-unification-fixture",
  "schemaVersion": 1,
  "description": "WorkerProviderRepairRollbackUnificationGateV1 fixture coverage for provider/worker/compound/operator repair rollback unification.",
  "requiredGates": [
    "WorkerProviderRepairRollbackUnificationGateV1",
    "same_signature_failure_repair_rollback_regression",
    "provider_worker_state_change_writes_rollback_policy",
    "exhausted_failure_blocks_unpaused_rerun",
    "provider_worker_refs_preserve_manifest_request_log_rollback",
    "compound_provider_retry_window_closes_same_signature",
    "regression_gate_refs_match_repair_queue",
    "provider_worker_live_state_change_repair_matrix",
    "multi_attempt_retry_window_completion_chain",
    "provider_worker_state_lineage_snapshot_matrix",
    "compound_provider_long_horizon_repair_completion_chain",
    "remote_provider_state_changing_repair_matrix",
    "deep_compound_provider_ten_attempt_repair_chain",
    "remote_provider_eight_state_changing_repair_matrix",
    "deep_compound_provider_repair_completion_chain"
  ],
  "scenarios": [
    {
      "id": "provider-worker-state-change",
      "source": "provider-worker",
      "mustBind": [
        "FailureLedgerEventV1",
        "RepairQueueItemV1",
        "RepairRollbackPolicyV1",
        "runtimeManifestFile",
        "requestLogFile",
        "regressionGateRefs",
        "ProviderWorkerLiveRepairMatrixV1",
        "provider_worker_live_state_change_repair_matrix"
      ]
    },
    {
      "id": "swarm-worker-provider-repair",
      "source": "provider-worker",
      "mustBind": [
        "SubagentRuntimeManifestV1",
        "WorkerChildSessionRuntimeBatchV1",
        "RepairRollbackPolicyV1",
        "requestLogFile",
        "ProviderWorkerLiveRepairMatrixV1",
        "provider_worker_live_state_change_repair_matrix"
      ]
    },
    {
      "id": "compound-frontier-retry-window",
      "source": "compound-frontier",
      "mustBind": [
        "sameSignatureRetryWindow",
        "closedCompletion",
        "regressionGateRefs",
        "MultiAttemptRetryWindowCompletionChainV1",
        "multi_attempt_retry_window_completion_chain"
      ]
    },
    {
      "id": "operator-exhausted-escalation",
      "source": "re_operator",
      "mustBind": [
        "status=exhausted",
        "remainingAttempts=0",
        "paused=true",
        "action=escalate",
        "MultiAttemptRetryWindowCompletionChainV1",
        "multi_attempt_retry_window_completion_chain"
      ]
    },
    {
      "id": "provider-worker-cache-state-repair",
      "source": "provider-worker",
      "mustBind": [
        "ProviderWorkerStateLineageSnapshotMatrixV1",
        "baselineTreeSha256",
        "mutationScopeSha256",
        "restoredTreeSha256",
        "requestLogFile",
        "runtimeManifestFile",
        "provider_worker_state_lineage_snapshot_matrix",
        "long-horizon provider chain"
      ]
    },
    {
      "id": "swarm-worker-tool-state-repair",
      "source": "provider-worker",
      "mustBind": [
        "ProviderWorkerStateLineageSnapshotMatrixV1",
        "ToolCallTraceLedgerV1",
        "SubagentRuntimeManifestV1",
        "RepairRollbackPolicyV1",
        "state lineage",
        "provider_worker_state_lineage_snapshot_matrix"
      ]
    },
    {
      "id": "compound-provider-long-horizon-repair",
      "source": "compound-frontier",
      "mustBind": [
        "CompoundProviderLongHorizonRepairCompletionChainV1",
        "five attempts",
        "sameSignatureRetryWindow",
        "regressionProofSha256 per attempt",
        "compound_provider_long_horizon_repair_completion_chain"
      ]
    },
    {
      "id": "provider-worker-token-state-repair",
      "source": "provider-worker",
      "mustBind": [
        "RemoteProviderStateChangingRepairMatrixV1",
        "remote_provider_state_changing_repair_matrix",
        "requestLogFile",
        "runtimeManifestFile",
        "RepairRollbackPolicyV1",
        "baselineTreeSha256",
        "restoredTreeSha256",
        "env-ref-only secrets"
      ]
    },
    {
      "id": "remote-provider-config-state-repair",
      "source": "provider-worker",
      "mustBind": [
        "RemoteProviderStateChangingRepairMatrixV1",
        "remote provider config repair",
        "five attempts",
        "sameSignatureRetryWindow",
        "rollback policy",
        "regression proof"
      ]
    },
    {
      "id": "compound-provider-deep-repair",
      "source": "compound-frontier",
      "mustBind": [
        "DeepCompoundProviderRepairCompletionChainV1",
        "seven attempts",
        "sameSignatureRetryWindow",
        "runtime refs per attempt",
        "regressionProofSha256 per attempt",
        "deep_compound_provider_repair_completion_chain"
      ]
    }
  ],
  "negativeCases": [
    {
      "id": "signature-mismatch",
      "mutates": "repairQueueItem.signature",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "missing-rollback-policy",
      "mutates": "scenario.rollbackPolicy",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "exhausted-unpaused-rerun",
      "mutates": "exhausted repair paused=false action=rerun",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "missing-provider-request-log-ref",
      "mutates": "runtimeRefs.requestLogFile",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "regression-gate-mismatch",
      "mutates": "repairQueueItem.regressionGates",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "policy-failure-repair-unlinked",
      "mutates": "rollbackPolicy.repairQueue",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "live-repair-matrix-missing-provider",
      "mutates": "liveRepairMatrix removes anthropic-compatible provider row",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "retry-window-not-monotonic",
      "mutates": "retryWindowCompletionChain attempts are not strictly increasing",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "completion-without-regression-proof",
      "mutates": "retryWindowCompletionChain regressionProofSha256 and gate refs removed",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "state-lineage-missing-baseline",
      "mutates": "stateLineageSnapshotMatrix.rows[0].baselineTreeSha256",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "long-horizon-chain-too-short",
      "mutates": "longHorizonRepairCompletionChain compound chain truncated to three attempts",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "long-horizon-signature-drift",
      "mutates": "longHorizonRepairCompletionChain.attempts[1].signature",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "remote-state-repair-matrix-too-narrow",
      "mutates": "remoteProviderStateChangingRepairMatrix.rows truncated below six rows",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "deep-compound-chain-too-short",
      "mutates": "deepCompoundProviderRepairCompletionChain compound-provider-deep-repair chain truncated below five attempts",
      "expect": "reject",
      "mustNotPromote": true
    },
    {
      "id": "remote-state-repair-secret-leak",
      "mutates": "remoteProviderStateChangingRepairMatrix.rows[0].requestLogFile contains a literal token-like secret",
      "expect": "reject",
      "mustNotPromote": true
    }
  ],
  "promotionPolicy": {
    "mode": "block-until-signature-policy-regression-pass",
    "requiresFailureRepairBatch": true,
    "requiresRollbackPolicyForStateChange": true,
    "requiresProviderWorkerRuntimeRefs": true,
    "requiresNoUnpausedRerunWhenExhausted": true,
    "requiresProviderWorkerLiveRepairMatrix": true,
    "requiresMultiAttemptRetryWindowCompletion": true,
    "requiresProviderWorkerStateLineageSnapshotMatrix": true,
    "requiresCompoundProviderLongHorizonRepairCompletion": true,
    "requiresRemoteProviderStateChangingRepairMatrix": true,
    "requiresDeepCompoundProviderRepairCompletion": true,
    "requiresRemoteProviderEightStateChangingRepairMatrix": true,
    "requiresDeepCompoundTenAttemptRepairChain": true
  },
  "invariants": [
    "worker_provider_repair_rollback_unification_gate",
    "same_signature_failure_repair_rollback_regression",
    "provider_worker_state_change_writes_rollback_policy",
    "exhausted_failure_blocks_unpaused_rerun",
    "provider_worker_refs_preserve_manifest_request_log_rollback",
    "compound_provider_retry_window_closes_same_signature",
    "regression_gate_refs_match_repair_queue",
    "provider_worker_live_state_change_repair_matrix",
    "multi_attempt_retry_window_completion_chain",
    "provider_worker_state_lineage_snapshot_matrix",
    "compound_provider_long_horizon_repair_completion_chain",
    "remote_provider_state_changing_repair_matrix",
    "deep_compound_provider_ten_attempt_repair_chain",
    "remote_provider_eight_state_changing_repair_matrix",
    "deep_compound_provider_repair_completion_chain"
  ]
}
