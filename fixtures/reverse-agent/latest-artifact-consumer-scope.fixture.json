{
  "kind": "repi-latest-artifact-consumer-scope-fixture",
  "schemaVersion": 1,
  "requiredGates": [
    "LatestArtifactConsumerScopeGateV1",
    "operator_feedback_latest_artifact_consumer",
    "proof_loop_gap_latest_artifact_consumer",
    "proof_loop_evidence_latest_artifact_consumer",
    "proof_loop_source_latest_artifact_consumer",
    "compiler_claim_gate_latest_artifact_consumer",
    "cross_target_latest_artifact_blocked",
    "same_target_older_artifact_selected"
  ],
  "scenarios": [
    {
      "id": "operator-feedback-cross-target-block",
      "consumer": "operator-feedback",
      "mustSelectSameTargetOlderArtifact": true,
      "mustBlockCrossTargetLatestArtifact": true
    },
    {
      "id": "proof-loop-gap-cross-target-block",
      "consumer": "proof-loop-gap",
      "mustSelectSameTargetOlderArtifact": true,
      "mustBlockCrossTargetLatestArtifact": true
    },
    {
      "id": "proof-loop-evidence-cross-target-block",
      "consumer": "proof-loop-evidence",
      "mustSelectSameTargetOlderArtifact": true,
      "mustBlockCrossTargetLatestArtifact": true
    },
    {
      "id": "proof-loop-source-cross-target-block",
      "consumer": "proof-loop-source",
      "mustSelectSameTargetOlderArtifact": true,
      "mustBlockCrossTargetLatestArtifact": true
    },
    {
      "id": "compiler-claim-gate-cross-target-block",
      "consumer": "compiler-claim-gate",
      "mustSelectSameTargetOlderArtifact": true,
      "mustBlockCrossTargetLatestArtifact": true
    }
  ],
  "negativeCases": [
    {
      "id": "cross-target-latest-leak",
      "expect": "TARGET_A_BLOCKED marker must not appear in target B operator/proof/compiler outputs"
    },
    {
      "id": "same-target-older-dropped",
      "expect": "TARGET_B_ALLOWED marker must remain available after the newer cross-target artifact is filtered"
    }
  ]
}
