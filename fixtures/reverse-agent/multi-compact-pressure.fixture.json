{
  "kind": "repi-multi-compact-pressure-fixture",
  "schemaVersion": 1,
  "requiredGates": [
    "MultiCompactPressureGateV1",
    "multi_compact_append_only_pressure",
    "old_context_path_over_latest_fallback",
    "duplicate_resume_idempotency_replay",
    "auto_resume_budget_exhaustion_pressure",
    "scope_artifact_drift_negative_cases",
    "operator_proof_loop_compact_writeback"
  ],
  "runtimePressurePlan": {
    "kind": "MultiCompactPressureGateV1",
    "probe": "scripts/reverse-agent/multi-compact-pressure-gate.mjs",
    "usesRealTools": ["re_context pack", "re_context resume", "re_memory compact-resume", "session_before_compact", "session_compact", "re_operator dispatch", "re_proof_loop run"],
    "boundedOffline": true,
    "evidencePath": ".repi-harness/evidence/multi-compact-pressure/<timestamp>/result.json"
  },
  "validScenarios": [
    {
      "id": "two-independent-compact-cycles",
      "expectedTransitions": ["queued->queued", "queued->running", "running->done"],
      "mustRemainAppendOnly": true,
      "mustEmbedCompactResumeLedgerV2": true
    },
    {
      "id": "old-context-path-beats-latest",
      "setup": "create pack A, create newer pack B, resume using explicit contextPath for A",
      "expect": "loadedBy=contextPath and resumedFromContextPath equals pack A, not latest pack B",
      "mustNotUseLatestFallback": true
    },
    {
      "id": "duplicate-resume-idempotent",
      "setup": "resume the same exact contextPath twice",
      "expect": "second replay does not append duplicate transition rows",
      "mustRemainAppendOnly": true
    },
    {
      "id": "operator-proof-loop-writeback",
      "setup": "trigger REPI-owned compaction hooks, then run bounded re_operator dispatch and re_proof_loop run",
      "expect": "compact_resume_telemetry transition is written into CompactResumeLedgerV2",
      "mustBindToTelemetry": true
    }
  ],
  "negativeCases": [
    {
      "id": "target-unresolved",
      "expect": "context pack not found",
      "mustNotPromote": true
    },
    {
      "id": "latest-fallback-without-explicit-ref",
      "expect": "explicit old contextPath is required to beat latest fallback",
      "mustNotPromote": true
    },
    {
      "id": "scope-mismatch",
      "expect": "target mismatch",
      "mustNotPromote": true
    },
    {
      "id": "artifact-drift",
      "expect": "artifact hash drift",
      "mustNotPromote": true
    },
    {
      "id": "budget-exhausted",
      "expect": "auto_resume_budget_exceeded",
      "mustNotPromote": true
    }
  ]
}
