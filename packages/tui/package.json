{
	"name": "@repi/tui",
	"version": "0.1.3",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"type": "module",
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"test": "node --test test/*.test.ts",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"native/win32/prebuilds/**/*.node",
		"native/darwin/prebuilds/**/*.node",
		"README.md"
	],
	"keywords": [
		"repi",
		"tui",
		"terminal",
		"cli",
		"differential-rendering"
	],
	"author": "REPI Contributors",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/multi-zhangyang/repi.git",
		"directory": "packages/tui"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"dependencies": {
		"get-east-asian-width": "1.6.0",
		"marked": "15.0.12"
	},
	"devDependencies": {
		"@xterm/headless": "5.5.0",
		"chalk": "5.6.2"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://github.com/multi-zhangyang/repi/tree/main/packages/tui",
	"bugs": {
		"url": "https://github.com/multi-zhangyang/repi/issues"
	}
}
